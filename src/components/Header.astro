---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE, CONTACT_EMAIL } from "../consts";
---

<header>
	<nav aria-label="Primary navigation">
		<a class="brand" href="/">
			<span class="brand-mark">TG</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/president-trades">President Trades</HeaderLink>
			<HeaderLink href="/pricing">Pricing</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
		<a class="nav-cta" href={`mailto:${CONTACT_EMAIL}?subject=Register%20Your%20Interest`}>Register Your Interest</a>
	</nav>
</header>

<style>
	header {
		background: #07111f;
		border-bottom: 1px solid rgba(109, 199, 255, 0.18);
	}

	nav {
		display: flex;
		min-width: 0;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 16px 0;
	}

	a {
		text-decoration: none;
	}

	.brand {
		display: inline-flex;
		min-width: 0;
		align-items: center;
		gap: 10px;
		color: #ffffff;
		font-weight: 900;
		overflow-wrap: anywhere;
	}

	.brand-mark {
		display: grid;
		width: 38px;
		height: 38px;
		place-items: center;
		border: 1px solid rgba(109, 199, 255, 0.5);
		border-radius: 9px;
		background: linear-gradient(135deg, #132c4f, #07111f);
		color: #69d5ff;
		box-shadow: 0 0 24px rgba(42, 178, 255, 0.35);
		font-size: 0.84rem;
	}

	.internal-links {
		display: flex;
		min-width: 0;
		flex-wrap: wrap;
		gap: 18px;
		align-items: center;
	}

	.internal-links a {
		color: #c7d8e8;
		font-size: 0.95rem;
		font-weight: 800;
	}

	.internal-links a:hover,
	.internal-links a.active {
		color: #ffffff;
	}

	.nav-cta {
		display: inline-flex;
		min-height: 42px;
		align-items: center;
		justify-content: center;
		padding: 10px 16px;
		border-radius: 8px;
		background: linear-gradient(135deg, #f0c85a, #d6a935);
		color: #07111f;
		font-weight: 900;
		box-shadow: 0 12px 28px rgba(214, 169, 53, 0.2);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.nav-cta:hover {
		transform: translateY(-1px);
		box-shadow: 0 0 26px rgba(214, 169, 53, 0.34);
	}

	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
		}

		.internal-links {
			width: 100%;
			justify-content: flex-start;
			gap: 10px 16px;
		}

		.nav-cta {
			width: 100%;
		}
	}

	@media (max-width: 380px) {
		.internal-links {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.internal-links a {
			font-size: 0.9rem;
		}
	}
</style>
