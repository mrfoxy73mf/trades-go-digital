---
import { CONTACT_EMAIL, SITE_DESCRIPTION } from "../consts";

const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div>
			<a class="brand" href="/">Trades Go Digital</a>
			<p>{SITE_DESCRIPTION}</p>
		</div>
		<div class="footer-links">
			<a href="/president-trades">President Trades</a>
			<a href="/about">About</a>
			<a href="/contact">Contact Trades Go Digital</a>
			<span>LinkedIn</span>
			<span>Facebook</span>
			<a href={`mailto:${CONTACT_EMAIL}`}>Email</a>
		</div>
	</div>
	<p class="copyright">Copyright &copy; {today.getFullYear()} Trades Go Digital</p>
</footer>

<style>
	footer {
		background: #07111f;
		color: #c7d8e8;
		border-top: 1px solid rgba(109, 199, 255, 0.16);
	}

	.footer-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 32px;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 42px 0 24px;
	}

	.brand {
		color: #ffffff;
		font-size: 1.1rem;
		font-weight: 900;
		text-decoration: none;
	}

	p {
		max-width: 620px;
		margin: 10px 0 0;
		overflow-wrap: anywhere;
	}

	.footer-links {
		display: grid;
		gap: 10px;
		text-align: right;
	}

	a {
		color: #c7d8e8;
		font-weight: 800;
		overflow-wrap: anywhere;
		text-decoration: none;
	}

	span {
		color: #7d91a8;
		font-weight: 800;
	}

	a:hover {
		color: #ffffff;
	}

	.copyright {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 0 0 30px;
		color: #7d91a8;
		font-size: 0.9rem;
	}

	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
		}

		.footer-links {
			text-align: left;
		}
	}
</style>
