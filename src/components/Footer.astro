---
const today = new Date();

const footerContacts = [
	{ label: "General Enquiries", email: "hello@trades-go-digital.co.uk" },
	{ label: "Customer Support", email: "support@trades-go-digital.co.uk" },
	{ label: "Report a Bug", email: "feedback@trades-go-digital.co.uk" },
	{ label: "Accounts & Invoices", email: "invoices@trades-go-digital.co.uk" },
];

const companyLinks = [
	{ label: "About Us", href: "/" },
	{ label: "Pricing", href: "/pricing" },
	{ label: "President Trades", href: "/president-trades" },
	{ label: "Contact", href: "/contact" },
];

const resourceLinks = [
	{ label: "Business Apps", href: "/" },
	{ label: "Software Updates", href: "/monthly-updates" },
	{ label: "AI Updates", href: "/monthly-updates" },
	{ label: "Blog", href: "/monthly-updates" },
	{ label: "Monthly News", href: "/monthly-updates" },
];
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<a class="brand" href="/">Trades Go Digital</a>
			<p>Helping UK trade businesses grow through websites, local SEO, automation and bespoke software.</p>
			<a class="footer-cta" href="/contact/#president-trades-enquiry">Get a Free Consultation</a>
		</div>

		<div class="footer-columns">
			<section class="footer-contact-list" aria-label="Footer contact emails">
				<h2>Contact</h2>
				{
					footerContacts.map((item) => (
						<p>
							<span>{item.label}</span>
							<a href={`mailto:${item.email}`}>{item.email}</a>
						</p>
					))
				}
			</section>

			<section class="footer-links" aria-label="Company links">
				<h2>Company</h2>
				{companyLinks.map((link) => <a href={link.href}>{link.label}</a>)}
			</section>

			<section class="footer-links" aria-label="Resource links">
				<h2>Resources</h2>
				{resourceLinks.map((link) => <a href={link.href}>{link.label}</a>)}
			</section>
		</div>
	</div>

	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Trades Go Digital Ltd.</p>
		<p>Built in the UK 🇬🇧</p>
		<a href="/terms-and-conditions">Terms &amp; Conditions</a>
	</div>
</footer>

<style>
	footer {
		background: #07111f;
		color: #c7d8e8;
		border-top: 1px solid rgba(109, 199, 255, 0.16);
	}

	.footer-inner {
		display: grid;
		gap: 34px;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 54px 0 34px;
		align-items: start;
	}

	.footer-brand {
		display: grid;
		justify-items: center;
		gap: 14px;
		max-width: 720px;
		margin: 0 auto;
		padding-bottom: 34px;
		text-align: center;
		border-bottom: 1px solid rgba(109, 199, 255, 0.14);
	}

	.brand {
		display: inline-flex;
		color: #ffffff;
		font-size: clamp(1.45rem, 3vw, 2rem);
		font-weight: 900;
		text-decoration: none;
	}

	p {
		max-width: 620px;
		margin: 0;
		overflow-wrap: anywhere;
	}

	.footer-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 12px 18px;
		border-radius: 8px;
		background: linear-gradient(135deg, #f0c85a, #d6a935);
		color: #07111f;
		font-weight: 900;
		text-decoration: none;
		box-shadow: 0 14px 30px rgba(214, 169, 53, 0.18);
	}

	.footer-columns {
		display: grid;
		grid-template-columns: minmax(280px, 1.35fr) repeat(2, minmax(160px, 0.65fr));
		gap: 24px;
		align-items: stretch;
	}

	.footer-contact-list,
	.footer-links {
		display: grid;
		gap: 10px;
		min-width: 0;
		height: 100%;
		padding: 22px;
		border: 1px solid rgba(109, 199, 255, 0.24);
		border-radius: 10px;
		background: linear-gradient(180deg, rgba(11, 25, 48, 0.92), rgba(5, 14, 27, 0.92));
		box-shadow: 0 18px 44px rgba(0, 0, 0, 0.18);
	}

	.footer-contact-list p {
		display: grid;
		gap: 5px;
		padding: 8px 0 0;
		border-top: 1px solid rgba(109, 199, 255, 0.12);
	}

	.footer-contact-list p:first-of-type {
		border-top: 0;
		padding-top: 0;
	}

	.footer-contact-list span {
		color: #ffffff;
		font-weight: 900;
	}

	.footer-contact-list a {
		color: #d8ecff;
		font-weight: 900;
	}

	a {
		color: #c7d8e8;
		font-weight: 800;
		overflow-wrap: anywhere;
		text-decoration: none;
	}

	h2 {
		margin: 0 0 12px;
		color: #69d5ff;
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.footer-links a {
		display: inline-flex;
	}

	a:hover {
		color: #ffffff;
	}

	.footer-bottom {
		display: grid;
		grid-template-columns: 1fr auto auto;
		width: min(1120px, calc(100% - 32px));
		align-items: center;
		gap: 24px;
		margin: 0 auto;
		padding: 22px 0 30px;
		border-top: 1px solid rgba(109, 199, 255, 0.12);
		color: #7d91a8;
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.footer-bottom p {
		margin: 0;
	}

	.footer-bottom a {
		color: #c7d8e8;
		font-weight: 900;
		white-space: nowrap;
	}

	.footer-bottom a:hover {
		color: #ffffff;
	}

	@media (min-width: 921px) {
		.footer-columns {
			grid-template-columns: minmax(520px, 1.4fr) repeat(2, minmax(170px, 0.55fr));
		}

		.footer-contact-list p {
			grid-template-columns: minmax(148px, 0.42fr) minmax(0, 1fr);
			gap: 16px;
			align-items: center;
		}

		.footer-contact-list span,
		.footer-contact-list a,
		.footer-links a {
			white-space: nowrap;
		}
	}

	@media (max-width: 920px) {
		.footer-columns {
			grid-template-columns: 1fr;
		}

		.footer-bottom {
			grid-template-columns: 1fr;
			gap: 8px;
			justify-items: start;
		}
	}

	@media (max-width: 720px) {
		.footer-inner {
			gap: 26px;
			padding: 38px 0 28px;
		}

		.footer-brand {
			justify-items: start;
			text-align: left;
		}
	}

	@media (max-width: 420px) {
		.footer-links,
		.footer-contact-list {
			padding: 18px;
		}
	}
</style>
