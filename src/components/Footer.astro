---
import { CONTACT_EMAIL, SITE_DESCRIPTION } from "../consts";

const today = new Date();

const footerColumns = [
	{
		title: "Industries",
		links: [
			{
				label: "Software world updates",
				href: "/",
				note: "Monthly notes on what is changing in software, AI and business tools.",
			},
		],
	},
	{
		title: "Topics",
		links: [
			{ label: "New software", href: "/" },
			{ label: "AI updates", href: "/" },
			{ label: "President Trades updates", href: "/president-trades" },
			{ label: "Business apps", href: "/" },
		],
	},
	{
		title: "About",
		links: [
			{ label: "About Trades Go Digital", href: "/" },
			{ label: "President Trades", href: "/president-trades" },
			{ label: "Pricing", href: "/pricing" },
		],
	},
	{
		title: "News",
		links: [
			{
				label: "Monthly updates",
				href: "/",
				note: "Future plans, product progress and new features.",
			},
			{ label: "Contact us", href: "/contact" },
		],
	},
];
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<a class="brand" href="/">Trades Go Digital</a>
			<p>{SITE_DESCRIPTION}</p>
			<a class="email-link" href={`mailto:${CONTACT_EMAIL}`}>Email: {CONTACT_EMAIL}</a>
		</div>
		<div class="footer-links" aria-label="Footer navigation">
			{
				footerColumns.map((column) => (
					<section>
						<h2>{column.title}</h2>
						{column.links.map((link) => (
							<a href={link.href}>
								<span>{link.label}</span>
								{link.note && <small>{link.note}</small>}
							</a>
						))}
					</section>
				))
			}
		</div>
	</div>
	<p class="copyright">Copyright &copy; {today.getFullYear()} Trades Go Digital</p>
</footer>

<style>
	footer {
		background: #07111f;
		color: #c7d8e8;
		border-top: 1px solid rgba(109, 199, 255, 0.16);
	}

	.footer-inner {
		display: grid;
		grid-template-columns: minmax(230px, 0.85fr) minmax(0, 1.65fr);
		gap: 32px;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 46px 0 28px;
	}

	.brand {
		color: #ffffff;
		font-size: 1.1rem;
		font-weight: 900;
		text-decoration: none;
	}

	p {
		max-width: 620px;
		margin: 10px 0 0;
		overflow-wrap: anywhere;
	}

	.email-link {
		display: inline-flex;
		margin-top: 18px;
	}

	.footer-links {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 22px;
	}

	a {
		color: #c7d8e8;
		font-weight: 800;
		overflow-wrap: anywhere;
		text-decoration: none;
	}

	h2 {
		margin: 0 0 12px;
		color: #ffffff;
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.footer-links section {
		display: grid;
		align-content: start;
		gap: 10px;
	}

	.footer-links a {
		display: grid;
		gap: 3px;
	}

	small {
		color: #7d91a8;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.35;
	}

	a:hover {
		color: #ffffff;
	}

	.copyright {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 0 0 30px;
		color: #7d91a8;
		font-size: 0.9rem;
	}

	@media (max-width: 920px) {
		.footer-inner,
		.footer-links {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
		}

		.footer-links {
			grid-template-columns: 1fr;
		}
	}
</style>
