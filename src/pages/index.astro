---
const services = [
  {
    title: "AI Websites",
    text: "Modern websites built to convert visitors into calls, enquiries and booked jobs.",
  },
  {
    title: "Local SEO",
    text: "Improve search visibility across your town, service areas and high-value trade keywords.",
  },
  {
    title: "Google Business Profile",
    text: "Optimise your profile so more local customers trust you, call you and request quotes.",
  },
  {
    title: "AI Voice Receptionists",
    text: "Answer calls, capture job details and reduce missed opportunities while you are working.",
  },
  {
    title: "Automation",
    text: "Connect lead capture, follow-ups and simple admin so enquiries keep moving.",
  },
];

const trades = [
  "Plumbers",
  "Electricians",
  "Builders",
  "Roofers",
  "Landscapers",
  "Heating engineers",
  "Decorators",
  "Local trade teams",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Trades Go Digital | Digital Growth for UK Trades Businesses</title>
    <meta
      name="description"
      content="Trades Go Digital helps UK trades businesses win more work, reduce admin and grow through practical digital solutions."
    />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Trades Go Digital home">
        <span class="brand-mark">TG</span>
        <span>Trades Go Digital</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/president-trades/">President Trades</a>
        <a href="#services">Services</a>
        <a href="#who">Who we help</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-bg"></div>
        <div class="container hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Helping UK Trades Businesses Grow</p>
            <h1>More leads. More jobs. Less admin.</h1>
            <p class="hero-text">
              Trades Go Digital helps UK trades businesses win more work,
              reduce admin and grow through practical digital solutions.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="mailto:mac@trades-go-digital.co.uk">
                Register Your Interest
              </a>
              <a class="button button-secondary" href="#services">Explore services</a>
            </div>
          </div>

          <div class="hero-visual" aria-label="Builder AI front cover artwork">
            <div class="hero-image-frame">
              <img
                src="/images/company-builder-ai-front-cover.png"
                alt="Business software concept showing a laptop with connected digital service panels"
                width="1024"
                height="1536"
              />
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="section services-section">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Services</p>
            <h2>Everything your trade business needs to generate better local enquiries.</h2>
          </div>

          <div class="services-grid">
            {
              services.map((service) => (
                <article class="service-card">
                  <h3>{service.title}</h3>
                  <p>{service.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="who" class="section who-section">
        <div class="container split">
          <div>
            <p class="eyebrow">Who we help</p>
            <h2>Built for local trades that need reliable enquiry flow.</h2>
            <p>
              We focus on practical digital systems for businesses where missed
              calls, weak Google visibility and slow follow-up cost real jobs.
              The aim is simple: more quality enquiries from the areas you
              actually serve.
            </p>
          </div>
          <div class="trade-list" aria-label="Trades we help">
            {trades.map((trade) => <span>{trade}</span>)}
          </div>
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div class="container contact-panel">
          <div>
            <p class="eyebrow">Start the conversation</p>
            <h2>Ready to make your trade business easier to find and easier to book?</h2>
            <p>
              Register your interest with your trade, location and current website
              or Google profile. We will send updates and early access details as
              new services become available.
            </p>
          </div>
          <a class="button button-primary" href="mailto:mac@trades-go-digital.co.uk">
            mac@trades-go-digital.co.uk
          </a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    background: #07111f;
    color: #edf6ff;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    line-height: 1.6;
  }

  :global(a) {
    color: inherit;
  }

  .container {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px max(20px, calc((100vw - 1180px) / 2));
    border-bottom: 1px solid rgba(109, 199, 255, 0.18);
    background: rgba(7, 17, 31, 0.78);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 10px;
    color: #ffffff;
    font-weight: 900;
    overflow-wrap: anywhere;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid rgba(109, 199, 255, 0.5);
    border-radius: 9px;
    background: linear-gradient(135deg, #132c4f, #07111f);
    color: #69d5ff;
    box-shadow: 0 0 24px rgba(42, 178, 255, 0.35);
    font-size: 0.84rem;
  }

  nav {
    display: flex;
    min-width: 0;
    flex-wrap: wrap;
    gap: 22px;
  }

  nav a {
    color: #c7d8e8;
    font-size: 0.95rem;
    font-weight: 750;
    text-decoration: none;
  }

  nav a:hover {
    color: #ffffff;
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 128px 0 92px;
    min-height: 100vh;
    background:
      radial-gradient(circle at 78% 18%, rgba(54, 178, 255, 0.28), transparent 30%),
      radial-gradient(circle at 20% 82%, rgba(214, 169, 53, 0.2), transparent 28%),
      linear-gradient(135deg, #0b1930 0%, #07111f 48%, #0c1725 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(109, 199, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(109, 199, 255, 0.08) 1px, transparent 1px);
    background-size: 70px 70px;
    mask-image: linear-gradient(to bottom, transparent, black 20%, black 72%, transparent);
    opacity: 0.24;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(520px, 1.1fr);
    gap: 56px;
    align-items: center;
  }

  .hero-copy,
  .hero-visual,
  .split > *,
  .contact-panel > * {
    min-width: 0;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: #d6a935;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 780px;
    margin-bottom: 24px;
    color: #ffffff;
    font-size: clamp(3.7rem, 8.4vw, 7.2rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 18px;
    color: #ffffff;
    font-size: clamp(2.2rem, 4.2vw, 4rem);
    line-height: 1;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 12px;
    color: #ffffff;
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .hero-text {
    max-width: 650px;
    color: #c7d8e8;
    font-size: 1.17rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    max-width: 100%;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 14px 22px;
    border-radius: 8px;
    font-weight: 900;
    overflow-wrap: anywhere;
    text-align: center;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: linear-gradient(135deg, #f0c85a, #d6a935);
    color: #07111f;
    box-shadow: 0 16px 38px rgba(214, 169, 53, 0.24);
  }

  .button-secondary {
    border: 1px solid rgba(109, 199, 255, 0.45);
    background: rgba(109, 199, 255, 0.08);
    color: #ffffff;
  }

  .button-secondary:hover {
    border-color: rgba(109, 199, 255, 0.9);
    background: rgba(109, 199, 255, 0.14);
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-image-frame {
    position: relative;
    width: min(100%, 570px);
    overflow: hidden;
    border: 1px solid rgba(109, 199, 255, 0.24);
    border-radius: 24px;
    background: rgba(10, 25, 45, 0.54);
    box-shadow:
      0 32px 100px rgba(0, 0, 0, 0.38),
      0 0 56px rgba(42, 178, 255, 0.18);
  }

  .hero-image-frame::after {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: inset 0 0 70px rgba(7, 17, 31, 0.2);
    content: "";
    pointer-events: none;
  }

  .hero-image-frame img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 3;
    object-fit: cover;
  }

  .section {
    padding: 94px 0;
  }

  .services-section {
    background: #f5f8fb;
    color: #0b1930;
  }

  .section-heading {
    max-width: 860px;
    margin-bottom: 34px;
  }

  .services-section h2,
  .who-section h2 {
    color: #0b1930;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 16px;
  }

  .service-card {
    min-height: 235px;
    padding: 24px;
    border: 1px solid rgba(12, 31, 55, 0.1);
    border-radius: 10px;
    background: #ffffff;
    box-shadow: 0 20px 50px rgba(12, 31, 55, 0.07);
  }

  .service-card h3 {
    color: #0b1930;
  }

  .service-card p,
  .who-section p,
  .contact-section p {
    color: #536174;
  }

  .who-section {
    background: #ffffff;
    color: #0b1930;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    gap: 56px;
    align-items: center;
  }

  .trade-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .trade-list span {
    padding: 15px 16px;
    border: 1px solid #d9e2ec;
    border-radius: 8px;
    background: #f5f8fb;
    color: #0b1930;
    font-weight: 850;
  }

  .contact-section {
    padding: 92px 0;
    background:
      radial-gradient(circle at 12% 20%, rgba(105, 213, 255, 0.16), transparent 28%),
      #07111f;
  }

  .contact-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 34px;
    align-items: center;
    padding: 42px;
    border: 1px solid rgba(109, 199, 255, 0.22);
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(14, 35, 63, 0.92), rgba(8, 20, 35, 0.92));
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.32);
  }

  .contact-panel h2 {
    max-width: 780px;
  }

  .contact-panel p {
    max-width: 720px;
    margin-bottom: 0;
    color: #c7d8e8;
  }

  @media (max-width: 1080px) {
    .hero-grid,
    .split,
    .contact-panel {
      grid-template-columns: 1fr;
    }

    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .contact-panel {
      align-items: start;
    }
  }

  @media (max-width: 760px) {
    .site-header {
      position: static;
      flex-direction: column;
      align-items: flex-start;
      padding: 16px;
    }

    nav {
      width: 100%;
      justify-content: flex-start;
      gap: 10px 18px;
    }

    nav a {
      font-size: 0.88rem;
    }

    .hero {
      min-height: auto;
      padding: 58px 0 64px;
    }

    h1 {
      font-size: clamp(3.2rem, 16vw, 4.8rem);
    }

    h2 {
      font-size: 2.25rem;
    }

    .button {
      width: 100%;
      min-height: 50px;
      text-align: center;
    }

    .hero-grid {
      gap: 30px;
    }

    .hero-visual {
      padding-top: 12px;
    }

    .hero-image-frame {
      width: min(100%, 430px);
      border-radius: 18px;
    }

    .services-grid,
    .trade-list {
      grid-template-columns: 1fr;
    }

    .section,
    .contact-section {
      padding: 62px 0;
    }

    .service-card {
      min-height: auto;
    }

    .contact-panel {
      padding: 26px;
      border-radius: 12px;
    }
  }

  @media (max-width: 380px) {
    nav {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    h1 {
      font-size: clamp(2.75rem, 15vw, 3.4rem);
    }
  }
</style>
