---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

const faqs = [
	{
		question: "Do I need internet on site?",
		answer:
			"No. Log jobs, snap receipts and take voice notes offline in the van or a loft. Everything syncs the moment you get signal, so nothing gets lost.",
	},
	{
		question: "Does this replace my accountant?",
		answer:
			"It replaces the shoebox, not the accountant. Come year-end, one tap can send a tidy monthly report with receipts, mileage, VAT, dividends and the rest, giving your accountant cleaner records to work from.",
	},
	{
		question: "What if I need to switch phones or jack it in?",
		answer:
			"Your data is yours. Full CSV and PDF backup export is available any time, and you can cancel in one tap with no 12-month contracts and no call-to-cancel nonsense.",
	},
	{
		question: "Is my customer data safe?",
		answer:
			"Data is encrypted in transit, stored on secure UK-region servers and backed up daily. Sensitive sections such as Wages, Tax and Archives are locked behind a separate PIN.",
	},
	{
		question: "I am not great with tech. Will I get lost?",
		answer:
			"If you can send a WhatsApp, you can use President Trades. The AI Assistant works like texting a mate: log diesel, book a customer in, or ask how much you earned this month.",
	},
	{
		question: "Will HMRC be happy with it?",
		answer:
			"Yes. Every job, receipt and mile is stored digitally in the format HMRC Making Tax Digital rules require, so VAT return figures are already in the right shape.",
	},
	{
		question: "Can I bring my last few months' records in from another app?",
		answer:
			"Yes. Go to Settings, then Bring Your History, and upload a CSV export from Xero, QuickBooks, Sage or your spreadsheet. President Trades auto-maps the columns and imports jobs, expenses and mileage in one shot.",
	},
	{
		question: "What happens if I lose my phone?",
		answer:
			"Nothing important. Your data lives on secure UK-region servers, not on your phone. Grab any phone, log back in, and every job, receipt, mile and PDF is where you left it. Two-factor login in V2 and full CSV/PDF backups add extra peace of mind.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Contact Trades Go Digital about President Trades, the business operating system for UK trade businesses."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<p class="eyebrow">Contact</p>
				<h1>Ask about President Trades.</h1>
				<a class="email-card" href={`mailto:${CONTACT_EMAIL}`}>
					<span>Email Mac</span>
					<strong>{CONTACT_EMAIL}</strong>
				</a>
			</section>

			<section class="faq-section" aria-labelledby="faq-title">
				<p class="eyebrow">Questions and answers</p>
				<h2 id="faq-title">What trades usually ask first</h2>
				<div class="faq-list">
					{
						faqs.map((item) => (
							<article>
								<h3>{item.question}</h3>
								<p>{item.answer}</p>
							</article>
						))
					}
				</div>
			</section>

			<section
				id="president-trades-enquiry"
				class="contact-enquiry"
				aria-labelledby="president-trades-enquiry-title"
			>
				<div class="contact-visual">
					<img
						src="/images/president-trades-contact-message.png"
						alt="President Trades contact message and business office visual"
					/>
				</div>
				<div class="message-panel">
					<div class="message-intro">
						<div class="message-icon" aria-hidden="true">PT</div>
						<div>
							<p class="eyebrow">Get in touch</p>
							<h2 id="president-trades-enquiry-title">Send a message to President Trades.</h2>
							<p>
								Tell us a little about your business and how President Trades could help.
								We will get back to you as soon as we can.
							</p>
						</div>
					</div>
					<form action={`mailto:${CONTACT_EMAIL}`} method="post" enctype="text/plain">
						<label>
							Your name
							<input name="Name" type="text" autocomplete="name" placeholder="Your name" required />
						</label>
						<label>
							Business name
							<input name="Business name" type="text" placeholder="Your business name" />
						</label>
						<label>
							Your trade
							<input name="Trade" type="text" placeholder="Plumber, electrician, builder..." required />
						</label>
						<label>
							Email or phone
							<input name="Contact" type="text" autocomplete="email" placeholder="How should we reply?" required />
						</label>
						<label class="full">
							Message
							<textarea
								name="Message"
								placeholder="Tell us what you want to know about President Trades."
								required
							></textarea>
						</label>
						<button type="submit">
							<span>Send message</span>
							<span aria-hidden="true">-&gt;</span>
						</button>
						<p class="form-note">
							This opens your email app so you can send the message to <strong>{CONTACT_EMAIL}</strong>.
						</p>
						<p class="safe-note">Your details are safe with us. We will never share your information.</p>
					</form>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background:
			radial-gradient(circle at 78% 12%, rgba(54, 178, 255, 0.18), transparent 28%),
			#07111f;
		color: #ffffff;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		overflow-x: hidden;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 76px 0;
	}

	.contact-hero {
		max-width: 850px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d6a935;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 22px;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.92;
	}

	h2 {
		margin: 0 0 22px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
	}

	h3 {
		margin: 0 0 10px;
		color: #ffffff;
		font-size: 1.1rem;
		line-height: 1.3;
	}

	p {
		color: #c7d8e8;
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.email-card {
		display: inline-grid;
		gap: 5px;
		margin-top: 24px;
		padding: 22px 24px;
		border: 1px solid rgba(109, 199, 255, 0.35);
		border-radius: 14px;
		background: rgba(10, 25, 45, 0.82);
		color: #ffffff;
		text-decoration: none;
		box-shadow: 0 0 28px rgba(42, 178, 255, 0.2);
	}

	.email-card span {
		color: #69d5ff;
		font-size: 0.8rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.email-card strong {
		font-size: clamp(1.1rem, 4vw, 1.5rem);
		overflow-wrap: anywhere;
	}

	.faq-section {
		margin-top: 72px;
	}

	.faq-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.faq-list article {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.faq-list p {
		margin: 0;
	}

	.contact-enquiry {
		display: grid;
		grid-template-columns: minmax(0, 1.02fr) minmax(380px, 0.98fr);
		gap: 0;
		width: 100%;
		max-width: 100%;
		margin-top: 72px;
		overflow: hidden;
		border: 1px solid rgba(109, 199, 255, 0.22);
		border-radius: 20px;
		background:
			radial-gradient(circle at 35% 70%, rgba(255, 107, 24, 0.28), transparent 34%),
			rgba(255, 255, 255, 0.06);
		box-shadow: 0 28px 90px rgba(0, 0, 0, 0.34);
		scroll-margin-top: 90px;
	}

	.contact-enquiry p {
		margin-bottom: 0;
	}

	.contact-visual {
		position: relative;
		min-height: 680px;
		background: #020813;
	}

	.contact-visual img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: left center;
	}

	.message-panel {
		align-self: center;
		min-width: 0;
		margin: 28px;
		padding: 30px;
		border: 1px solid rgba(148, 169, 189, 0.34);
		border-radius: 18px;
		background: rgba(4, 13, 25, 0.9);
		box-shadow: 0 0 34px rgba(42, 178, 255, 0.14);
	}

	.message-intro {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 18px;
		align-items: start;
		margin-bottom: 26px;
		padding-bottom: 24px;
		border-bottom: 1px solid rgba(148, 169, 189, 0.25);
	}

	.message-icon {
		display: grid;
		width: 58px;
		height: 58px;
		place-items: center;
		border: 1px solid #ff6b18;
		border-radius: 50%;
		color: #ff6b18;
		font-size: 0.92rem;
		font-weight: 900;
		box-shadow: 0 0 24px rgba(255, 107, 24, 0.16);
	}

	.message-intro h2 {
		margin-bottom: 14px;
		font-size: clamp(2rem, 4.2vw, 3.55rem);
	}

	form {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	label {
		display: grid;
		gap: 8px;
		color: #ffffff;
		font-size: 0.94rem;
		font-weight: 900;
	}

	label.full,
	form button,
	.form-note {
		grid-column: 1 / -1;
	}

	input,
	textarea {
		width: 100%;
		min-width: 0;
		min-height: 52px;
		border: 1px solid rgba(109, 199, 255, 0.28);
		border-radius: 8px;
		background: rgba(7, 17, 31, 0.76);
		color: #ffffff;
		font: inherit;
		font-size: 1rem;
		padding: 14px;
	}

	textarea {
		min-height: 132px;
		resize: vertical;
	}

	input::placeholder,
	textarea::placeholder {
		color: #94a9bd;
	}

	form button {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		min-height: 54px;
		border: 0;
		border-radius: 8px;
		background: linear-gradient(135deg, #ff7a1a, #f0470e);
		color: #ffffff;
		font: inherit;
		font-weight: 900;
		cursor: pointer;
		box-shadow: 0 0 28px rgba(255, 107, 24, 0.28);
	}

	.form-note {
		margin: 0;
		color: #c7d8e8;
		font-size: 0.95rem;
	}

	.form-note strong {
		color: #ffffff;
		overflow-wrap: anywhere;
	}

	.safe-note {
		grid-column: 1 / -1;
		margin: 4px 0 0;
		padding-top: 14px;
		border-top: 1px solid rgba(148, 169, 189, 0.18);
		color: #c7d8e8;
		font-size: 0.95rem;
		font-weight: 900;
	}

	@media (max-width: 760px) {
		main {
			width: min(100% - 24px, 1120px);
			padding: 50px 0;
			overflow-x: hidden;
		}

		.faq-list,
		.contact-enquiry,
		form {
			grid-template-columns: 1fr;
		}

		.email-card {
			width: 100%;
		}

		.contact-enquiry {
			display: block;
			border-radius: 14px;
		}

		.contact-visual {
			display: none;
		}

		.message-panel {
			margin: 0;
			padding: 24px;
			border: 0;
			border-radius: 14px;
		}

		.message-intro {
			grid-template-columns: 1fr;
		}

		.message-intro h2 {
			font-size: clamp(2rem, 11vw, 3rem);
		}
	}
</style>
