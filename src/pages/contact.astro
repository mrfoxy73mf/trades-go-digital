---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

const faqs = [
	{
		question: "Do I need internet on site?",
		answer:
			"No. Log jobs, snap receipts and take voice notes offline in the van or a loft. Everything syncs the moment you get signal, so nothing gets lost.",
	},
	{
		question: "Does this replace my accountant?",
		answer:
			"It replaces the shoebox, not the accountant. Come year-end, one tap can send a tidy monthly report with receipts, mileage, VAT, dividends and the rest, giving your accountant cleaner records to work from.",
	},
	{
		question: "What if I need to switch phones or jack it in?",
		answer:
			"Your data is yours. Full CSV and PDF backup export is available any time, and you can cancel in one tap with no 12-month contracts and no call-to-cancel nonsense.",
	},
	{
		question: "Is my customer data safe?",
		answer:
			"Data is encrypted in transit, stored on secure UK-region servers and backed up daily. Sensitive sections such as Wages, Tax and Archives are locked behind a separate PIN.",
	},
	{
		question: "I am not great with tech. Will I get lost?",
		answer:
			"If you can send a WhatsApp, you can use President Trades. The AI Assistant works like texting a mate: log diesel, book a customer in, or ask how much you earned this month.",
	},
	{
		question: "Will HMRC be happy with it?",
		answer:
			"Yes. Every job, receipt and mile is stored digitally in the format HMRC Making Tax Digital rules require, so VAT return figures are already in the right shape.",
	},
	{
		question: "Can I bring my last few months' records in from another app?",
		answer:
			"Yes. Go to Settings, then Bring Your History, and upload a CSV export from Xero, QuickBooks, Sage or your spreadsheet. President Trades auto-maps the columns and imports jobs, expenses and mileage in one shot.",
	},
	{
		question: "What happens if I lose my phone?",
		answer:
			"Nothing important. Your data lives on secure UK-region servers, not on your phone. Grab any phone, log back in, and every job, receipt, mile and PDF is where you left it. Two-factor login in V2 and full CSV/PDF backups add extra peace of mind.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Contact Trades Go Digital about President Trades, the business operating system for UK trade businesses."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<p class="eyebrow">Contact</p>
				<h1>Ask about President Trades.</h1>
				<a class="email-card" href={`mailto:${CONTACT_EMAIL}`}>
					<span>Email Mac</span>
					<strong>{CONTACT_EMAIL}</strong>
				</a>
			</section>

			<section class="faq-section" aria-labelledby="faq-title">
				<p class="eyebrow">Questions and answers</p>
				<h2 id="faq-title">What trades usually ask first</h2>
				<div class="faq-list">
					{
						faqs.map((item) => (
							<article>
								<h3>{item.question}</h3>
								<p>{item.answer}</p>
							</article>
						))
					}
				</div>
			</section>

			<section
				id="president-trades-enquiry"
				class="contact-enquiry"
				aria-labelledby="president-trades-enquiry-title"
			>
				<div>
					<p class="eyebrow">Register your interest</p>
					<h2 id="president-trades-enquiry-title">Send a message about President Trades.</h2>
					<p>
						Tell us a bit about your trade business and what you want President Trades to help
						with. Your message will open in your email app ready to send.
					</p>
				</div>
				<form action={`mailto:${CONTACT_EMAIL}`} method="post" enctype="text/plain">
					<label>
						Your name
						<input name="Name" type="text" autocomplete="name" placeholder="Your name" required />
					</label>
					<label>
						Business name
						<input name="Business name" type="text" placeholder="Your business name" />
					</label>
					<label>
						Your trade
						<input name="Trade" type="text" placeholder="Plumber, electrician, builder..." required />
					</label>
					<label>
						Email or phone
						<input name="Contact" type="text" autocomplete="email" placeholder="How should we reply?" required />
					</label>
					<label class="full">
						Message
						<textarea
							name="Message"
							placeholder="Tell us what you want to know about President Trades."
							required
						></textarea>
					</label>
					<button type="submit">Send message</button>
					<p class="form-note">
						This opens your email app so you can send the message to {CONTACT_EMAIL}.
					</p>
				</form>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background:
			radial-gradient(circle at 78% 12%, rgba(54, 178, 255, 0.18), transparent 28%),
			#07111f;
		color: #ffffff;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 76px 0;
	}

	.contact-hero {
		max-width: 850px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d6a935;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 22px;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.92;
	}

	h2 {
		margin: 0 0 22px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
	}

	h3 {
		margin: 0 0 10px;
		color: #ffffff;
		font-size: 1.1rem;
		line-height: 1.3;
	}

	p {
		color: #c7d8e8;
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.email-card {
		display: inline-grid;
		gap: 5px;
		margin-top: 24px;
		padding: 22px 24px;
		border: 1px solid rgba(109, 199, 255, 0.35);
		border-radius: 14px;
		background: rgba(10, 25, 45, 0.82);
		color: #ffffff;
		text-decoration: none;
		box-shadow: 0 0 28px rgba(42, 178, 255, 0.2);
	}

	.email-card span {
		color: #69d5ff;
		font-size: 0.8rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.email-card strong {
		font-size: clamp(1.1rem, 4vw, 1.5rem);
		overflow-wrap: anywhere;
	}

	.faq-section {
		margin-top: 72px;
	}

	.faq-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.faq-list article {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.faq-list p {
		margin: 0;
	}

	.contact-enquiry {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(340px, 1.18fr);
		gap: 30px;
		margin-top: 72px;
		padding: 30px;
		border: 1px solid rgba(109, 199, 255, 0.22);
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.07);
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.2);
		scroll-margin-top: 90px;
	}

	.contact-enquiry p {
		margin-bottom: 0;
	}

	form {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	label {
		display: grid;
		gap: 8px;
		color: #ffffff;
		font-size: 0.94rem;
		font-weight: 900;
	}

	label.full,
	form button,
	.form-note {
		grid-column: 1 / -1;
	}

	input,
	textarea {
		width: 100%;
		min-width: 0;
		min-height: 52px;
		border: 1px solid rgba(109, 199, 255, 0.28);
		border-radius: 8px;
		background: rgba(7, 17, 31, 0.76);
		color: #ffffff;
		font: inherit;
		font-size: 1rem;
		padding: 14px;
	}

	textarea {
		min-height: 132px;
		resize: vertical;
	}

	input::placeholder,
	textarea::placeholder {
		color: #94a9bd;
	}

	form button {
		min-height: 54px;
		border: 0;
		border-radius: 8px;
		background: #ff6b18;
		color: #ffffff;
		font: inherit;
		font-weight: 900;
		cursor: pointer;
	}

	.form-note {
		margin: 0;
		color: #c7d8e8;
		font-size: 0.95rem;
	}

	@media (max-width: 760px) {
		main {
			padding: 50px 0;
		}

		.faq-list,
		.contact-enquiry,
		form {
			grid-template-columns: 1fr;
		}

		.email-card {
			width: 100%;
		}

		.contact-enquiry {
			padding: 24px;
		}
	}
</style>
