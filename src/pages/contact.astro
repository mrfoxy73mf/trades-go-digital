---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

export const prerender = false;

const faqs = [
	{
		question: "Do I need internet on site?",
		answer:
			"No. Log jobs, snap receipts and take voice notes offline in the van or a loft. Everything syncs the moment you get signal, so nothing gets lost.",
	},
	{
		question: "Does this replace my accountant?",
		answer:
			"It replaces the shoebox, not the accountant. Come year-end, one tap can send a tidy monthly report with receipts, mileage, VAT, dividends and the rest, giving your accountant cleaner records to work from.",
	},
	{
		question: "What if I need to switch phones or jack it in?",
		answer:
			"Your data is yours. Full CSV and PDF backup export is available any time, and you can cancel in one tap with no 12-month contracts and no call-to-cancel nonsense.",
	},
	{
		question: "Is my customer data safe?",
		answer:
			"Data is encrypted in transit, stored on secure UK-region servers and backed up daily. Sensitive sections such as Wages, Tax and Archives are locked behind a separate PIN.",
	},
	{
		question: "I am not great with tech. Will I get lost?",
		answer:
			"If you can send a WhatsApp, you can use President Trades. The AI Assistant works like texting a mate: log diesel, book a customer in, or ask how much you earned this month.",
	},
	{
		question: "Will HMRC be happy with it?",
		answer:
			"Yes. Every job, receipt and mile is stored digitally in the format HMRC Making Tax Digital rules require, so VAT return figures are already in the right shape.",
	},
	{
		question: "Can I bring my last few months' records in from another app?",
		answer:
			"Yes. Go to Settings, then Bring Your History, and upload a CSV export from Xero, QuickBooks, Sage or your spreadsheet. President Trades auto-maps the columns and imports jobs, expenses and mileage in one shot.",
	},
	{
		question: "What happens if I lose my phone?",
		answer:
			"Nothing important. Your data lives on secure UK-region servers, not on your phone. Grab any phone, log back in, and every job, receipt, mile and PDF is where you left it. Two-factor login in V2 and full CSV/PDF backups add extra peace of mind.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Contact Trades Go Digital about President Trades, the business operating system for UK trade businesses."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<p class="eyebrow">Contact</p>
				<h1>Ask about President Trades.</h1>
				<a class="email-card" href={`mailto:${CONTACT_EMAIL}`}>
					<span>Email Mac</span>
					<strong>{CONTACT_EMAIL}</strong>
				</a>
			</section>

			<section class="faq-section" aria-labelledby="faq-title">
				<p class="eyebrow">Questions and answers</p>
				<h2 id="faq-title">What trades usually ask first</h2>
				<div class="faq-list">
					{
						faqs.map((item) => (
							<article>
								<h3>{item.question}</h3>
								<p>{item.answer}</p>
							</article>
						))
					}
				</div>
			</section>

			<section
				id="president-trades-enquiry"
				class="contact-enquiry"
				aria-label="President Trades enquiry form"
			>
				<div class="message-panel">
					<div class="message-intro">
						<div class="message-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" role="img" aria-label="">
								<path d="M7.5 11.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm9 0a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7ZM2.8 20c.6-3.4 2.7-5.2 6.1-5.2h1.2c1 0 1.9.2 2.7.6-1 1.1-1.6 2.6-1.9 4.6H2.8Zm9.8 0c.5-3.4 2.5-5.2 5.6-5.2h1c3 0 4.9 1.8 5.4 5.2h-12Z" />
							</svg>
						</div>
						<div>
							<p class="message-lead">Join hundreds of trades preparing for launch.</p>
							<p class="message-sub">Tell us how President Trades could help your business.</p>
						</div>
					</div>
					<form id="president-trades-form" data-email={CONTACT_EMAIL}>
						<label>
							Your name
							<input name="Name" type="text" autocomplete="name" placeholder="Your name" required />
						</label>
						<label>
							Business name
							<input name="Business name" type="text" placeholder="Your business name" />
						</label>
						<label>
							Your trade
							<input name="Trade" type="text" placeholder="Plumber, electrician, builder..." required />
						</label>
						<label>
							Email or phone
							<input name="Contact" type="text" autocomplete="email" placeholder="How should we reply?" required />
						</label>
						<label class="full">
							Message
							<textarea
								name="Message"
								placeholder="Tell us what you want to know about President Trades."
								required
							></textarea>
						</label>
						<button type="submit">
							<span>Send message</span>
							<span aria-hidden="true">-&gt;</span>
						</button>
						<p class="form-note">
							This opens your email app so you can send the message to <strong>{CONTACT_EMAIL}</strong>.
						</p>
					</form>
					<p class="safe-note">Your details are safe with us. We will never share your information.</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background:
			radial-gradient(circle at 78% 12%, rgba(54, 178, 255, 0.18), transparent 28%),
			#07111f;
		color: #ffffff;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		overflow-x: hidden;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 76px 0;
	}

	.contact-hero {
		max-width: 850px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d6a935;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 22px;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.92;
	}

	h2 {
		margin: 0 0 22px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
	}

	h3 {
		margin: 0 0 10px;
		color: #ffffff;
		font-size: 1.1rem;
		line-height: 1.3;
	}

	p {
		color: #c7d8e8;
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.email-card {
		display: inline-grid;
		gap: 5px;
		margin-top: 24px;
		padding: 22px 24px;
		border: 1px solid rgba(109, 199, 255, 0.35);
		border-radius: 14px;
		background: rgba(10, 25, 45, 0.82);
		color: #ffffff;
		text-decoration: none;
		box-shadow: 0 0 28px rgba(42, 178, 255, 0.2);
	}

	.email-card span {
		color: #69d5ff;
		font-size: 0.8rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.email-card strong {
		font-size: clamp(1.1rem, 4vw, 1.5rem);
		overflow-wrap: anywhere;
	}

	.faq-section {
		margin-top: 72px;
	}

	.faq-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.faq-list article {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.faq-list p {
		margin: 0;
	}

	.contact-enquiry {
		display: grid;
		grid-template-columns: 1fr;
		gap: 24px;
		width: 100%;
		max-width: 100%;
		margin-top: 72px;
		scroll-margin-top: 90px;
	}

	.contact-enquiry p {
		margin-bottom: 0;
	}

	.message-panel {
		align-self: stretch;
		min-width: 0;
		margin: 0;
		padding: clamp(24px, 3vw, 40px);
		border: 1px solid rgba(148, 169, 189, 0.38);
		border-radius: 20px;
		background:
			linear-gradient(180deg, rgba(7, 18, 32, 0.96), rgba(3, 10, 20, 0.96)),
			rgba(4, 13, 25, 0.92);
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.32), 0 0 34px rgba(42, 178, 255, 0.12);
	}

	.message-intro {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 18px;
		align-items: center;
		margin-bottom: 26px;
		padding-bottom: 24px;
		border-bottom: 1px solid rgba(148, 169, 189, 0.25);
	}

	.message-icon {
		display: grid;
		width: 64px;
		height: 64px;
		place-items: center;
		border: 1px solid #ff6b18;
		border-radius: 50%;
		color: #ff6b18;
		box-shadow: 0 0 24px rgba(255, 107, 24, 0.16);
	}

	.message-icon svg {
		width: 28px;
		height: 28px;
		fill: currentColor;
	}

	.message-lead {
		margin: 0;
		color: #ffffff;
		font-size: clamp(1.08rem, 2vw, 1.28rem);
		font-weight: 800;
		line-height: 1.45;
	}

	.message-sub {
		margin: 4px 0 0;
		color: #c7d8e8;
		font-size: 0.98rem;
		line-height: 1.55;
	}

	form {
		display: grid;
		grid-template-columns: repeat(2, minmax(260px, 1fr));
		gap: 18px;
	}

	label {
		display: grid;
		gap: 8px;
		color: #ffffff;
		font-size: 0.94rem;
		font-weight: 900;
	}

	label.full,
	form button,
	.form-note {
		grid-column: 1 / -1;
	}

	input,
	textarea {
		width: 100%;
		min-width: 0;
		min-height: 52px;
		border: 1px solid rgba(109, 199, 255, 0.28);
		border-radius: 8px;
		background: rgba(7, 17, 31, 0.76);
		color: #ffffff;
		font: inherit;
		font-size: 1rem;
		padding: 14px;
	}

	textarea {
		min-height: 132px;
		resize: vertical;
	}

	input::placeholder,
	textarea::placeholder {
		color: #94a9bd;
	}

	form button {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		min-height: 60px;
		border: 0;
		border-radius: 10px;
		background: linear-gradient(135deg, #ff7a1a, #f0470e);
		color: #ffffff;
		font: inherit;
		font-size: 1.05rem;
		font-weight: 900;
		cursor: pointer;
		box-shadow: 0 0 28px rgba(255, 107, 24, 0.28);
	}

	.form-note {
		margin: 0;
		color: #c7d8e8;
		font-size: 0.95rem;
	}

	.form-note strong {
		color: #ffffff;
		overflow-wrap: anywhere;
	}

	.safe-note {
		display: flex;
		gap: 12px;
		align-items: center;
		margin: 22px 0 0;
		padding-top: 20px;
		border-top: 1px solid rgba(148, 169, 189, 0.22);
		color: #c7d8e8;
		font-size: 0.95rem;
		font-weight: 900;
	}

	@media (max-width: 760px) {
		main {
			width: min(100% - 24px, 1120px);
			padding: 50px 0;
			overflow-x: hidden;
		}

		h1 {
			font-size: clamp(2.35rem, 13vw, 3.4rem);
			line-height: 0.98;
		}

		h2 {
			font-size: clamp(1.7rem, 9vw, 2.2rem);
			line-height: 1.05;
		}

		p {
			font-size: 1rem;
			line-height: 1.65;
		}

		.faq-list,
		.contact-enquiry,
		form {
			grid-template-columns: 1fr;
		}

		.email-card {
			width: 100%;
		}

		.contact-enquiry {
			display: grid;
			gap: 16px;
		}

		.message-panel {
			margin: 0;
			padding: 24px;
			border-radius: 14px;
		}

		.message-intro {
			grid-template-columns: auto minmax(0, 1fr);
		}
	}

	@media (max-width: 420px) {
		main {
			width: min(100% - 20px, 1120px);
			padding: 40px 0;
		}

		.faq-section,
		.contact-enquiry {
			margin-top: 48px;
		}

		.email-card,
		.faq-list article,
		.message-panel {
			border-radius: 10px;
		}

		.email-card,
		.faq-list article {
			padding: 18px;
		}

		.message-panel {
			padding: 18px;
		}

		.message-intro {
			grid-template-columns: 1fr;
			gap: 12px;
		}

		.message-icon {
			width: 52px;
			height: 52px;
		}
	}
</style>

<script>
	const form = document.querySelector("#president-trades-form");

	form?.addEventListener("submit", (event) => {
		event.preventDefault();

		const target = event.currentTarget;
		if (!(target instanceof HTMLFormElement)) return;

		const email = target.dataset.email;
		if (!email) return;

		const data = new FormData(target);
		const subject = "President Trades enquiry";
		const body = ["Name", "Business name", "Trade", "Contact", "Message"]
			.map((field) => `${field}: ${data.get(field) ?? ""}`)
			.join("\n\n");

		window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
	});
</script>
