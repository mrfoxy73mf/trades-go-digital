---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Contact Trades Go Digital about AI websites, Local SEO, Google Business Profile optimisation, AI voice receptionists and automation."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<p class="eyebrow">Contact</p>
				<h1>Tell us where your next leads should come from.</h1>
				<p>
					Send your trade, location and current website or Google Business Profile. We will help identify
					the simplest first step for improving enquiry flow.
				</p>
				<a class="email-card" href={`mailto:${CONTACT_EMAIL}`}>
					<span>Email Mac</span>
					<strong>{CONTACT_EMAIL}</strong>
				</a>
			</section>

			<section class="next-steps" aria-label="What to include in your email">
				<h2>Helpful details to include</h2>
				<div class="steps">
					<div>
						<strong>1. Trade and service area</strong>
						<p>Example: electrician in Manchester, roofer covering Leeds, plumber in Bristol.</p>
					</div>
					<div>
						<strong>2. Current online presence</strong>
						<p>Share your website, Google profile or any page you currently use for enquiries.</p>
					</div>
					<div>
						<strong>3. Main problem</strong>
						<p>Missed calls, low Google visibility, weak website conversion or slow follow-up.</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background:
			radial-gradient(circle at 78% 12%, rgba(54, 178, 255, 0.18), transparent 28%),
			#07111f;
		color: #ffffff;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 76px 0;
	}

	.contact-hero {
		max-width: 850px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d6a935;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 22px;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.92;
	}

	h2 {
		margin: 0 0 22px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
	}

	p {
		color: #c7d8e8;
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.email-card {
		display: inline-grid;
		gap: 5px;
		margin-top: 24px;
		padding: 22px 24px;
		border: 1px solid rgba(109, 199, 255, 0.35);
		border-radius: 14px;
		background: rgba(10, 25, 45, 0.82);
		color: #ffffff;
		text-decoration: none;
		box-shadow: 0 0 28px rgba(42, 178, 255, 0.2);
	}

	.email-card span {
		color: #69d5ff;
		font-size: 0.8rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.email-card strong {
		font-size: clamp(1.1rem, 4vw, 1.5rem);
		overflow-wrap: anywhere;
	}

	.next-steps {
		margin-top: 66px;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.steps div {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.steps strong {
		display: block;
		margin-bottom: 10px;
	}

	.steps p {
		margin: 0;
	}

	@media (max-width: 760px) {
		main {
			padding: 50px 0;
		}

		.steps {
			grid-template-columns: 1fr;
		}

		.email-card {
			width: 100%;
		}
	}
</style>
