---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

const faqs = [
	{
		question: "What does President Trades help me run?",
		answer:
			"It helps organise the business side of your trade: quotes, jobs, invoices, certificates, customer paperwork, notes, mileage, receipts and records.",
	},
	{
		question: "Can I connect President Trades to other services?",
		answer:
			"Yes. The app has a Connections area in Settings, built for linking useful services such as HMRC Making Tax Digital when those options are available.",
	},
	{
		question: "Does it help with quotes and jobs?",
		answer:
			"Yes. You create the quote once, then President Trades helps carry the details through into the job, invoice, paperwork and Business Office.",
	},
	{
		question: "Will it keep job paperwork together?",
		answer:
			"Yes. The Business Office is designed to keep each job's documents, receipts, certificates, notes and customer records organised in the right place.",
	},
	{
		question: "Can it help with tax and accountant records?",
		answer:
			"Yes. It is being built to keep records cleaner through the year, make accountant handover easier and support HMRC Making Tax Digital through Connections.",
	},
	{
		question: "Can I use it while I am out on jobs?",
		answer:
			"Yes. President Trades is designed around trades who work from vans, homes, sites and phones, not just from an office desk.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Contact Trades Go Digital about President Trades, the business operating system for UK trade businesses."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<p class="eyebrow">Contact</p>
				<h1>Ask about President Trades.</h1>
				<p>
					Send your trade, how you currently manage admin and what slows you down most. We will
					reply with the most useful next step for President Trades.
				</p>
				<a class="email-card" href={`mailto:${CONTACT_EMAIL}`}>
					<span>Email Mac</span>
					<strong>{CONTACT_EMAIL}</strong>
				</a>
			</section>

			<section class="next-steps" aria-label="What to include in your email">
				<h2>Helpful details to include</h2>
				<div class="steps">
					<div>
						<strong>1. Your trade</strong>
						<p>Example: plumber, electrician, roofer, builder, gas engineer or multi-trade business.</p>
					</div>
					<div>
						<strong>2. How you do admin now</strong>
						<p>Tell us if you use paper, spreadsheets, another app or a mix of different tools.</p>
					</div>
					<div>
						<strong>3. Main admin problem</strong>
						<p>Quotes, invoices, certificates, receipts, mileage, tax records or accountant paperwork.</p>
					</div>
				</div>
			</section>

			<section class="faq-section" aria-labelledby="faq-title">
				<p class="eyebrow">Questions and answers</p>
				<h2 id="faq-title">What trades usually ask first</h2>
				<div class="faq-list">
					{
						faqs.map((item) => (
							<article>
								<h3>{item.question}</h3>
								<p>{item.answer}</p>
							</article>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background:
			radial-gradient(circle at 78% 12%, rgba(54, 178, 255, 0.18), transparent 28%),
			#07111f;
		color: #ffffff;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 76px 0;
	}

	.contact-hero {
		max-width: 850px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d6a935;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 22px;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.92;
	}

	h2 {
		margin: 0 0 22px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
	}

	h3 {
		margin: 0 0 10px;
		color: #ffffff;
		font-size: 1.1rem;
		line-height: 1.3;
	}

	p {
		color: #c7d8e8;
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.email-card {
		display: inline-grid;
		gap: 5px;
		margin-top: 24px;
		padding: 22px 24px;
		border: 1px solid rgba(109, 199, 255, 0.35);
		border-radius: 14px;
		background: rgba(10, 25, 45, 0.82);
		color: #ffffff;
		text-decoration: none;
		box-shadow: 0 0 28px rgba(42, 178, 255, 0.2);
	}

	.email-card span {
		color: #69d5ff;
		font-size: 0.8rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.email-card strong {
		font-size: clamp(1.1rem, 4vw, 1.5rem);
		overflow-wrap: anywhere;
	}

	.next-steps {
		margin-top: 66px;
	}

	.faq-section {
		margin-top: 72px;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.steps div {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.steps strong {
		display: block;
		margin-bottom: 10px;
	}

	.steps p {
		margin: 0;
	}

	.faq-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.faq-list article {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.faq-list p {
		margin: 0;
	}

	@media (max-width: 760px) {
		main {
			padding: 50px 0;
		}

		.steps,
		.faq-list {
			grid-template-columns: 1fr;
		}

		.email-card {
			width: 100%;
		}
	}
</style>
