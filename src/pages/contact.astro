---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

const faqs = [
	{
		question: "Can you help if I already have a website?",
		answer:
			"Yes. We can look at what you already have and suggest the simplest improvement, whether that is clearer wording, better local pages, stronger calls to action or a cleaner enquiry route.",
	},
	{
		question: "What if most of my work comes from Google?",
		answer:
			"That is normal for trades. We can review your Google Business Profile, service areas, reviews, photos and website links so more local customers understand what you do and how to contact you.",
	},
	{
		question: "Can this help with missed calls?",
		answer:
			"Yes. If missed calls are costing you work, we can talk through better follow-up, enquiry forms, call handling and automation so customers are not left waiting.",
	},
	{
		question: "Do I need to know exactly what I want before emailing?",
		answer:
			"No. Send your trade, area and the problem you want to fix. We can help work out whether the first step should be your website, Google profile, follow-up process or President Trades.",
	},
	{
		question: "Is President Trades for small trade businesses?",
		answer:
			"Yes. It is being built around the everyday admin UK trades deal with: quotes, jobs, invoices, paperwork, records, mileage and accountant-ready information.",
	},
	{
		question: "How quickly will I hear back?",
		answer:
			"We aim to reply as soon as possible. Include the useful details above so the first reply can be practical instead of starting with basic questions.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Contact Trades Go Digital about AI websites, Local SEO, Google Business Profile optimisation, AI voice receptionists and automation."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<p class="eyebrow">Contact</p>
				<h1>Tell us where your next leads should come from.</h1>
				<p>
					Send your trade, location and current website or Google Business Profile. We will help identify
					the simplest first step for improving enquiry flow.
				</p>
				<a class="email-card" href={`mailto:${CONTACT_EMAIL}`}>
					<span>Email Mac</span>
					<strong>{CONTACT_EMAIL}</strong>
				</a>
			</section>

			<section class="next-steps" aria-label="What to include in your email">
				<h2>Helpful details to include</h2>
				<div class="steps">
					<div>
						<strong>1. Trade and service area</strong>
						<p>Example: electrician in Manchester, roofer covering Leeds, plumber in Bristol.</p>
					</div>
					<div>
						<strong>2. Current online presence</strong>
						<p>Share your website, Google profile or any page you currently use for enquiries.</p>
					</div>
					<div>
						<strong>3. Main problem</strong>
						<p>Missed calls, low Google visibility, weak website conversion or slow follow-up.</p>
					</div>
				</div>
			</section>

			<section class="faq-section" aria-labelledby="faq-title">
				<p class="eyebrow">Questions and answers</p>
				<h2 id="faq-title">What trades usually ask first</h2>
				<div class="faq-list">
					{
						faqs.map((item) => (
							<article>
								<h3>{item.question}</h3>
								<p>{item.answer}</p>
							</article>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background:
			radial-gradient(circle at 78% 12%, rgba(54, 178, 255, 0.18), transparent 28%),
			#07111f;
		color: #ffffff;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 76px 0;
	}

	.contact-hero {
		max-width: 850px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d6a935;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 22px;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.92;
	}

	h2 {
		margin: 0 0 22px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
	}

	h3 {
		margin: 0 0 10px;
		color: #ffffff;
		font-size: 1.1rem;
		line-height: 1.3;
	}

	p {
		color: #c7d8e8;
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.email-card {
		display: inline-grid;
		gap: 5px;
		margin-top: 24px;
		padding: 22px 24px;
		border: 1px solid rgba(109, 199, 255, 0.35);
		border-radius: 14px;
		background: rgba(10, 25, 45, 0.82);
		color: #ffffff;
		text-decoration: none;
		box-shadow: 0 0 28px rgba(42, 178, 255, 0.2);
	}

	.email-card span {
		color: #69d5ff;
		font-size: 0.8rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.email-card strong {
		font-size: clamp(1.1rem, 4vw, 1.5rem);
		overflow-wrap: anywhere;
	}

	.next-steps {
		margin-top: 66px;
	}

	.faq-section {
		margin-top: 72px;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.steps div {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.steps strong {
		display: block;
		margin-bottom: 10px;
	}

	.steps p {
		margin: 0;
	}

	.faq-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.faq-list article {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.faq-list p {
		margin: 0;
	}

	@media (max-width: 760px) {
		main {
			padding: 50px 0;
		}

		.steps,
		.faq-list {
			grid-template-columns: 1fr;
		}

		.email-card {
			width: 100%;
		}
	}
</style>
