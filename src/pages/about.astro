---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About | ${SITE_TITLE}`}
			description="Learn how Trades Go Digital helps UK trades businesses get more leads with AI websites, Local SEO and automation."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">About Trades Go Digital</p>
				<h1>Practical digital systems for busy UK trades businesses.</h1>
				<p>
					Trades Go Digital helps local trade businesses improve the parts of their online presence that
					directly affect lead flow: websites, Google visibility, missed calls, quote requests and
					follow-up.
				</p>
			</section>

			<section class="content-grid">
				<article>
					<h2>What we focus on</h2>
					<p>
						The goal is not to make digital marketing complicated. The goal is to make your business
						easier to find, easier to trust and easier to contact when a local customer needs a job done.
					</p>
				</article>
				<article>
					<h2>How we help</h2>
					<ul>
						<li>AI websites built around enquiries and quote requests.</li>
						<li>Local SEO for the towns and services that matter to your business.</li>
						<li>Google Business Profile improvements for calls, reviews and map visibility.</li>
						<li>AI voice receptionists and automation to capture leads when you are unavailable.</li>
					</ul>
				</article>
			</section>

			<section class="cta">
				<h2>Want to see what could be improved?</h2>
				<p>Email your trade, location and website or Google profile.</p>
				<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background: #f5f8fb;
		color: #0b1930;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 72px 0;
	}

	.page-hero {
		max-width: 820px;
		margin-bottom: 48px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #b58a1f;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 20px;
		font-size: clamp(2.7rem, 7vw, 5.2rem);
		line-height: 0.95;
	}

	h2 {
		margin: 0 0 14px;
		font-size: 1.45rem;
	}

	p,
	li {
		color: #536174;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.content-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	article,
	.cta {
		padding: 28px;
		border: 1px solid #d9e2ec;
		border-radius: 12px;
		background: #ffffff;
		box-shadow: 0 20px 50px rgba(12, 31, 55, 0.07);
	}

	ul {
		margin: 0;
		padding-left: 1.2rem;
	}

	.cta {
		margin-top: 18px;
		background: #07111f;
		color: #ffffff;
	}

	.cta h2 {
		color: #ffffff;
	}

	.cta p {
		color: #c7d8e8;
	}

	.cta a {
		display: inline-flex;
		margin-top: 10px;
		color: #d6a935;
		font-weight: 900;
		overflow-wrap: anywhere;
	}

	@media (max-width: 760px) {
		main {
			padding: 48px 0;
		}

		.content-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
