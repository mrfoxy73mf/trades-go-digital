---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

const pricingFeatures = [
	"Voice-activated AI Assistant (say it -> app logs it)",
	"HMRC MTD-compatible record-keeping",
	"Digital customer sign-off (CP12, EICR, JSO)",
	"Works offline in the van",
	"Auto parts ordering to suppliers",
	"Unlimited jobs, photos and PDFs",
	"Real-time cash-flow dashboard",
	"Import your history in one CSV upload",
	"Cancel anytime - no contract",
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Pricing | ${SITE_TITLE}`}
			description="Simple President Trades pricing for UK trades businesses. Register your interest for early access updates."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<div>
					<p class="eyebrow">President Trades pricing</p>
					<h1>Simple pricing for trade businesses.</h1>
					<p>
						Simple pricing with the core business office included, so you know what you are getting
						before you register your interest.
					</p>
				</div>
				<img
					src="/images/president-trades-pricing-van-v2.png"
					alt="President Trades worker showing the app beside a branded van"
				/>
			</section>

			<section class="pricing-card" aria-label="President Trades pricing">
				<div>
					<p class="eyebrow">Early access pricing</p>
					<div class="price"><b>&pound;28</b><span>/month</span></div>
					<p class="price-note">Less than &pound;1 a day for your first 2 months.</p>
					<p class="after-price">Then &pound;60 a month.</p>
				</div>
				<div>
					<h2>Included in the plan</h2>
					<ul>
						{pricingFeatures.map((item) => <li><span aria-hidden="true">&#10003;</span>{item}</li>)}
					</ul>
				</div>
			</section>

			<section class="one-tap">
				<h2>The one tap that runs your business.</h2>
				<p>Your customer accepts a quote. That's it. That's the tap.</p>
				<p>Job created. Parts ordered. Calendar booked. Paperwork filed. Accountant updated.</p>
				<p>All while you're still on the ladder.</p>
				<p>No other UK trade app does this. We built President Trades so you don't have to.</p>
			</section>

			<section class="cta">
				<h2>Register your interest</h2>
				<p>Join the early access list and get updates before President Trades launches.</p>
				<a href="/president-trades/#waiting-list">Register Your Interest</a>
			</section>

			<section class="pricing-enquiry" aria-labelledby="pricing-enquiry-title">
				<div>
					<p class="eyebrow">Ask for information</p>
					<h2 id="pricing-enquiry-title">Want to know if President Trades fits your business?</h2>
					<p>
						Send your details and what you want to know. We will reply with the most useful
						next step for your trade business.
					</p>
				</div>
				<form action={`mailto:${CONTACT_EMAIL}`} method="post" enctype="text/plain">
					<label>
						Your name
						<input name="Name" type="text" autocomplete="name" placeholder="Your name" required />
					</label>
					<label>
						Your trade
						<input name="Trade" type="text" placeholder="Plumber, electrician, roofer..." required />
					</label>
					<label>
						Email or phone
						<input name="Contact" type="text" autocomplete="email" placeholder="How should we reply?" required />
					</label>
					<label>
						Business size
						<input name="Business size" type="text" placeholder="Sole trader, small team, company..." />
					</label>
					<label class="full">
						What do you want to know?
						<textarea
							name="Message"
							placeholder="Ask about pricing, setup, early access or how President Trades works."
							required
						></textarea>
					</label>
					<button type="submit">Send enquiry</button>
					<p class="form-note">
						This opens your email app so you can send the enquiry to {CONTACT_EMAIL}.
					</p>
				</form>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background: #f5f8fb;
		color: #0b1930;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 72px 0;
	}

	.page-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1.15fr);
		gap: 34px;
		align-items: center;
		margin-bottom: 48px;
	}

	.page-hero img {
		width: 100%;
		border: 1px solid #d9e2ec;
		border-radius: 14px;
		background: #ffffff;
		box-shadow: 0 22px 60px rgba(12, 31, 55, 0.12);
		object-fit: cover;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #b58a1f;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 20px;
		font-size: clamp(2.7rem, 7vw, 5.2rem);
		line-height: 0.95;
	}

	h2 {
		margin: 0 0 14px;
		font-size: 1.45rem;
	}

	p,
	li {
		color: #536174;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.pricing-card {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 34px;
		align-items: start;
	}

	.pricing-card,
	.one-tap,
	.cta {
		padding: 28px;
		border: 1px solid #d9e2ec;
		border-radius: 12px;
		background: #ffffff;
		box-shadow: 0 20px 50px rgba(12, 31, 55, 0.07);
	}

	.price {
		display: flex;
		align-items: flex-end;
		gap: 10px;
		margin: 8px 0;
	}

	.price b {
		font-size: clamp(4rem, 12vw, 7rem);
		line-height: 0.9;
	}

	.price span,
	.after-price,
	.price-note {
		font-weight: 900;
	}

	.after-price {
		color: #0b1930;
	}

	ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		display: flex;
		gap: 10px;
		align-items: flex-start;
		padding: 10px 0;
		border-bottom: 1px solid #e6edf4;
	}

	li span {
		color: #ff6b18;
		font-weight: 900;
	}

	.one-tap {
		margin-top: 18px;
		text-align: center;
	}

	.one-tap h2 {
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1;
	}

	.one-tap p {
		max-width: 760px;
		margin: 0 auto 10px;
	}

	.one-tap p:first-of-type,
	.one-tap p:last-child {
		color: #0b1930;
		font-weight: 900;
	}

	.cta {
		margin-top: 18px;
		background: #07111f;
		color: #ffffff;
	}

	.cta h2 {
		color: #ffffff;
	}

	.cta p {
		color: #c7d8e8;
	}

	.cta a {
		display: inline-flex;
		margin-top: 10px;
		color: #d6a935;
		font-weight: 900;
		overflow-wrap: anywhere;
	}

	.pricing-enquiry {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(340px, 1.2fr);
		gap: 30px;
		margin-top: 18px;
		padding: 30px;
		border: 1px solid #d9e2ec;
		border-radius: 12px;
		background: #ffffff;
		box-shadow: 0 20px 50px rgba(12, 31, 55, 0.07);
	}

	.pricing-enquiry p {
		margin-bottom: 0;
	}

	form {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	label {
		display: grid;
		gap: 8px;
		color: #0b1930;
		font-size: 0.94rem;
		font-weight: 900;
	}

	label.full,
	form button,
	.form-note {
		grid-column: 1 / -1;
	}

	input,
	textarea {
		width: 100%;
		min-width: 0;
		min-height: 52px;
		border: 1px solid #cfd9e5;
		border-radius: 8px;
		background: #f8fbff;
		color: #0b1930;
		font: inherit;
		font-size: 1rem;
		padding: 14px;
	}

	textarea {
		min-height: 132px;
		resize: vertical;
	}

	input::placeholder,
	textarea::placeholder {
		color: #718096;
	}

	form button {
		min-height: 54px;
		border: 0;
		border-radius: 8px;
		background: #ff6b18;
		color: #ffffff;
		font: inherit;
		font-weight: 900;
		cursor: pointer;
	}

	.form-note {
		margin: 0;
		color: #536174;
		font-size: 0.95rem;
	}

	@media (max-width: 760px) {
		main {
			padding: 48px 0;
		}

		.page-hero {
			grid-template-columns: 1fr;
			gap: 24px;
		}

		.pricing-card {
			grid-template-columns: 1fr;
		}

		.pricing-enquiry,
		form {
			grid-template-columns: 1fr;
		}

		.pricing-enquiry {
			padding: 24px;
		}
	}
</style>
