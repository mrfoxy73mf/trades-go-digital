---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

const pricingFeatures = [
	"Quotes, jobs, invoices and certificates",
	"Business Office with organised job records",
	"Tax Centre and accountant bundle",
	"Notebook, voice notes and useful AI tools",
	"Vehicle, mileage and calendar",
	"Business branding on paperwork",
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Pricing | ${SITE_TITLE}`}
			description="Simple President Trades pricing for UK trades businesses. Register your interest for early access updates."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<div>
					<p class="eyebrow">President Trades pricing</p>
					<h1>Simple pricing for trade businesses.</h1>
					<p>
						Simple pricing with the core business office included, so you know what you are getting
						before you register your interest.
					</p>
				</div>
				<img
					src="/images/president-trades-pricing-van-v2.png"
					alt="President Trades worker showing the app beside a branded van"
				/>
			</section>

			<section class="pricing-card" aria-label="President Trades pricing">
				<div>
					<p class="eyebrow">Early access pricing</p>
					<div class="price"><b>&pound;28</b><span>/month</span></div>
					<p class="price-note">Less than &pound;1 a day for your first 2 months.</p>
					<p class="after-price">Then &pound;60 a month.</p>
				</div>
				<div>
					<h2>Included in the plan</h2>
					<ul>
						{pricingFeatures.map((item) => <li><span>✓</span>{item}</li>)}
					</ul>
				</div>
			</section>

			<section class="cta">
				<h2>Register your interest</h2>
				<p>Join the early access list and get updates before President Trades launches.</p>
				<a href="/president-trades/#waiting-list">Register Your Interest</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background: #f5f8fb;
		color: #0b1930;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 72px 0;
	}

	.page-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1.15fr);
		gap: 34px;
		align-items: center;
		margin-bottom: 48px;
	}

	.page-hero img {
		width: 100%;
		border: 1px solid #d9e2ec;
		border-radius: 14px;
		background: #ffffff;
		box-shadow: 0 22px 60px rgba(12, 31, 55, 0.12);
		object-fit: cover;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #b58a1f;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 20px;
		font-size: clamp(2.7rem, 7vw, 5.2rem);
		line-height: 0.95;
	}

	h2 {
		margin: 0 0 14px;
		font-size: 1.45rem;
	}

	p,
	li {
		color: #536174;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.pricing-card {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 34px;
		align-items: start;
	}

	.pricing-card,
	.cta {
		padding: 28px;
		border: 1px solid #d9e2ec;
		border-radius: 12px;
		background: #ffffff;
		box-shadow: 0 20px 50px rgba(12, 31, 55, 0.07);
	}

	.price {
		display: flex;
		align-items: flex-end;
		gap: 10px;
		margin: 8px 0;
	}

	.price b {
		font-size: clamp(4rem, 12vw, 7rem);
		line-height: 0.9;
	}

	.price span,
	.after-price,
	.price-note {
		font-weight: 900;
	}

	.after-price {
		color: #0b1930;
	}

	ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		display: flex;
		gap: 10px;
		align-items: flex-start;
		padding: 10px 0;
		border-bottom: 1px solid #e6edf4;
	}

	li span {
		color: #ff6b18;
		font-weight: 900;
	}

	.cta {
		margin-top: 18px;
		background: #07111f;
		color: #ffffff;
	}

	.cta h2 {
		color: #ffffff;
	}

	.cta p {
		color: #c7d8e8;
	}

	.cta a {
		display: inline-flex;
		margin-top: 10px;
		color: #d6a935;
		font-weight: 900;
		overflow-wrap: anywhere;
	}

	@media (max-width: 760px) {
		main {
			padding: 48px 0;
		}

		.page-hero {
			grid-template-columns: 1fr;
			gap: 24px;
		}

		.pricing-card {
			grid-template-columns: 1fr;
		}
	}
</style>
