		.pt-paperwork-visual.is-paperwork-open {
			width: min(860px, calc(100vw - 28px));
			max-width: none;
		}

		.pt-paperwork-visual.is-paperwork-open > img {
			width: 100%;
		}

		.pt-scroll-hint {
			position: absolute;
			left: 2.2%;
			top: 79.5%;
			z-index: 5;
			display: table;
			width: max-content;
			max-width: 240px;
			margin: 0;
			padding: 9px 13px;
			border: 1px solid rgba(255, 159, 28, 0.45);
			border-radius: 999px;
			background: rgba(8, 13, 20, 0.88);
			color: #ffb14d;
			font-size: 0.78rem;
			font-weight: 900;
			line-height: 1.15;
			box-shadow: 0 12px 30px rgba(0, 0, 0, 0.24);
			pointer-events: none;
		}

