		.pt-paperwork-visual {
			width: clamp(780px, 205vw, 980px);
			max-height: none;
			border-radius: 0;
		}

		.pt-paperwork-visual.is-paperwork-open {
			width: calc(100vw - 16px);
		}

		.pt-paperwork-menu {
			position: absolute;
			inset: 0;
			width: 100%;
			pointer-events: none;
		}

		.pt-paperwork-visual.is-paperwork-open .pt-paperwork-menu {
			display: none;
		}

