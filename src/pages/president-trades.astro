---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";

const adminProblems = [
	"Quotes waiting to be written after a long day on the tools",
	"Invoices, receipts and VAT records spread across apps, emails and folders",
	"Compliance certificates and job documents that need to be easy to find later",
	"Payment chasing that gets delayed because the next job has already started",
];

const stats = [
	["150+", "Hours saved each year"],
	["24/7", "Business organised"],
	["1", "App instead of many"],
];

const features = [
	["Quotes", "Fast visibility of quotes waiting to be sent or approved."],
	["Invoices", "See what has been billed, paid and still needs attention."],
	["Receipts", "Keep job costs and purchase records easier to manage."],
	["VAT", "Stay more organised around VAT-related admin."],
	["Certificates", "Keep compliance paperwork connected to the work."],
	["Payments", "Track unpaid work and follow-up without guesswork."],
	["Diary", "See what needs doing today, this week and next."],
	["Customers", "Keep job history and customer details in one place."],
];

const tradeCards = [
	{
		title: "Plumbers",
		text: "Keep quotes, materials, receipts, invoices and repeat customer jobs easier to manage.",
	},
	{
		title: "Gas engineers",
		text: "Stay organised around service visits, compliance paperwork, certificates and follow-up.",
	},
	{
		title: "Electricians",
		text: "Track job admin, quotes, payment status and customer details without losing evenings.",
	},
];

const comparisonRows = [
	["Built around trade jobs", "Jobs, customers, quotes and follow-up first", "Accounting records first"],
	["Day-to-day admin", "Focused on admin that happens around real jobs", "Often split across menus and categories"],
	["Compliance paperwork", "Certificates and job documents are part of the workflow", "Usually treated as attachments"],
	["Payment chasing", "Connected to the job and invoice status", "Usually handled separately"],
	["Trade owner experience", "Simple, practical and made for busy working days", "Often built for bookkeepers and accountants"],
];

const weekTimeline = [
	{
		day: "Monday",
		text: "A customer accepts your quote. Your diary is updated and your paperwork is organised before you even start work.",
	},
	{
		day: "Wednesday",
		text: "You photograph a receipt. It is attached to the correct job and stored ready for your accounts.",
	},
	{
		day: "Thursday",
		text: "The customer signs the job. Their paperwork is sent automatically.",
	},
	{
		day: "Friday",
		text: "Payment arrives. Your records are updated and everything stays organised.",
	},
	{
		day: "Sunday",
		text: "While you are relaxing, your accountant already has everything needed for the month.",
	},
	{
		day: "Year End",
		text: "Generate your year-end bundle and send it to your accountant in minutes instead of days.",
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`President Trades | Trade Admin Software Waiting List`}
			description="President Trades is a business operating system for UK trades businesses. Join the waiting list for UK plumbers, gas engineers and electricians."
		/>
		<meta property="og:site_name" content={SITE_TITLE} />
		<meta property="og:locale" content="en_GB" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero reveal">
				<div class="hero-bg"></div>
				<div class="container hero-grid">
					<div class="hero-copy">
						<p class="eyebrow">President Trades pre-launch</p>
						<h1>Stop spending evenings doing paperwork.</h1>
						<p class="hero-text">
							President Trades is a business operating system for UK trades businesses.
							It helps businesses stay on top of quotes, jobs, customers, invoices,
							receipts, VAT, certificates and payment chasing&mdash;all from one place.
						</p>
						<div class="hero-actions">
							<a class="button" href="#waiting-list">Join the waiting list</a>
							<a class="button secondary" href="#comparison">See how it compares</a>
						</div>
					</div>

					<div class="product-visual" aria-label="President Trades product preview">
						<div class="dashboard">
							<div class="dashboard-top">
								<div>
									<span>President Trades</span>
									<strong>Operations dashboard</strong>
								</div>
								<small>Today</small>
							</div>

							<div class="metric-grid">
								<div>
									<span>Today's Jobs</span>
									<strong>8</strong>
								</div>
								<div>
									<span>Quotes Awaiting Approval</span>
									<strong>6</strong>
								</div>
								<div>
									<span>Outstanding Invoices</span>
									<strong>GBP 4.8k</strong>
								</div>
								<div>
									<span>Certificates Ready</span>
									<strong>12</strong>
								</div>
							</div>

							<div class="dashboard-body">
								<div class="panel jobs-panel">
									<div class="panel-title">
										<strong>Today's Jobs</strong>
										<span>3 priority</span>
									</div>
									<p><b>08:30</b> Boiler service <span>Certificate due</span></p>
									<p><b>11:00</b> Bathroom leak <span>Quote needed</span></p>
									<p><b>15:30</b> Consumer unit <span>Invoice ready</span></p>
								</div>
								<div class="panel">
									<div class="panel-title">
										<strong>Customer Messages</strong>
										<span>5 new</span>
									</div>
									<div class="message-row">
										<span class="avatar">JL</span>
										<p>Can you confirm the quote for Friday?</p>
									</div>
									<div class="progress">
										<span style="width: 72%"></span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section light reveal">
				<div class="container split">
					<div class="narrow-copy">
						<p class="eyebrow">The admin problem</p>
						<h2>The work is done on site. The second shift starts at home.</h2>
						<p>
							Most trades businesses don't struggle because they lack work. They struggle because
							paperwork keeps following them home.
						</p>
					</div>
					<div class="problem-list">
						{adminProblems.map((problem) => <span>{problem}</span>)}
					</div>
				</div>
			</section>

			<section class="section dark reveal">
				<div class="container split">
					<div class="narrow-copy">
						<p class="eyebrow">Save over 150 hours a year</p>
						<h2>Get your evenings back from repeat admin.</h2>
						<p>
							If paperwork costs just three hours a week, that is more than 150 hours a year.
							President Trades is being built to reduce the repeat admin that slows down
							trade owners after the job is finished.
						</p>
					</div>
					<div class="stat-grid">
						{stats.map(([value, label]) => <article><strong>{value}</strong><span>{label}</span></article>)}
					</div>
				</div>
			</section>

			<section class="section light reveal">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">How it helps</p>
						<h2>A clearer way to manage the paperwork around every job.</h2>
					</div>
					<div class="card-grid">
						{
							features.map(([title, text]) => (
								<article class="card lift-card">
									<span class="feature-icon" aria-hidden="true">{title.slice(0, 1)}</span>
									<h3>{title}</h3>
									<p>{text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="comparison" class="section muted reveal">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">Comparison</p>
						<h2>President Trades vs Generic Accounting Software.</h2>
					</div>
					<div class="table-wrap">
						<table>
							<thead>
								<tr>
									<th>Need</th>
									<th class="pt-col">President Trades</th>
									<th>Generic accounting software</th>
								</tr>
							</thead>
							<tbody>
								{
									comparisonRows.map((row) => (
										<tr>
											<th>{row[0]}</th>
											<td class="pt-col" data-label="President Trades"><span class="tick">&#10003;</span>{row[1]}</td>
											<td data-label="Generic accounting software"><span class="minus">-</span>{row[2]}</td>
										</tr>
									))
								}
							</tbody>
						</table>
					</div>
				</div>
			</section>

			<section class="section dark reveal">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">Built for UK trades</p>
						<h2>For plumbers, gas engineers and electricians carrying the admin load.</h2>
					</div>
					<div class="trade-grid">
						{
							tradeCards.map((trade) => (
								<article class="trade-card lift-card">
									<h3>{trade.title}</h3>
									<p>{trade.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="section light reveal">
				<div class="container story-panel">
					<p class="eyebrow">How President Trades Started</p>
					<h2>It started with a simple request.</h2>
					<div class="story-copy">
						<p>President Trades started with a simple request.</p>
						<p>
							Someone asked me if I could help organise their business, so I built a few Excel
							spreadsheets on my laptop.
						</p>
						<p>
							The more I understood the day-to-day problems faced by trades businesses, the more I
							realised spreadsheets weren't enough.
						</p>
						<p>
							I discovered AI and used it as another tool to help me build something better.
						</p>
						<p>
							Over the following months, those spreadsheets evolved into President Trades &ndash; a
							business operating system designed to help UK trades businesses spend less time on
							paperwork and more time running their business.
						</p>
						<p>The ideas, workflows and purpose came from solving real problems.</p>
					</div>
				</div>
			</section>

			<section class="section light reveal">
				<div class="container story-panel">
					<p class="eyebrow">The Builder's Story</p>
					<div class="story-copy">
						<p>
							Builders don't blame the tools for a bad job&mdash;they learn how to use them properly.
						</p>
						<p>That's exactly how I approached President Trades.</p>
						<p>
							I didn't set out to build an AI app. I set out to solve real problems that UK trades
							businesses face every day.
						</p>
						<p>Every feature started with a real-world problem.</p>
						<p>
							AI became another tool in the toolbox. Used where it genuinely helps, but never allowed
							to take control of the business.
						</p>
						<p>
							President Trades is built around people, with technology working quietly in the
							background.
						</p>
					</div>
				</div>
			</section>

			<section class="section light reveal">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">A Week with President Trades</p>
						<h2>From quote accepted to year-end pack, the admin stays organised.</h2>
					</div>
					<div class="week-timeline">
						{
							weekTimeline.map((item) => (
								<article class="timeline-item lift-card">
									<span>{item.day}</span>
									<p>{item.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="waiting-list" class="cta-section reveal">
				<div class="container cta-panel">
					<div class="narrow-copy">
						<p class="eyebrow">Waiting list</p>
						<h2>Join the President Trades early access list.</h2>
						<p>
							Register your interest now. The form is frontend-only while the product is in
							pre-launch.
						</p>
						<p class="notice">Early access list opening soon.</p>
					</div>

					<form aria-label="President Trades waiting list form">
						<label>
							Name
							<input type="text" name="name" autocomplete="name" placeholder="Your name" />
						</label>
						<label>
							Business Name
							<input type="text" name="business" autocomplete="organization" placeholder="Business name" />
						</label>
						<label>
							Trade
							<select name="trade">
								<option value="">Select your trade</option>
								<option>Plumber</option>
								<option>Gas engineer</option>
								<option>Electrician</option>
								<option>Other UK trade</option>
							</select>
						</label>
						<label>
							Email
							<input type="email" name="email" autocomplete="email" placeholder="you@example.com" />
						</label>
						<label>
							Phone (optional)
							<input type="tel" name="phone" autocomplete="tel" placeholder="Your phone number" />
						</label>
						<label class="full">
							Message
							<textarea name="message" rows="4" placeholder="What admin problem would you most like solved?"></textarea>
						</label>
						<button type="button">Join the waiting list</button>
						<p class="form-note">No spam. We'll only contact you about President Trades.</p>
						<p class="form-note muted-note">This form is not connected yet. Early access list opening soon.</p>
					</form>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		margin: 0;
		background: #07111f;
		color: #ffffff;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	.container {
		width: min(1180px, calc(100% - 32px));
		margin: 0 auto;
	}

	.hero-copy,
	.product-visual,
	.narrow-copy,
	.section-heading,
	.split > *,
	.cta-panel > *,
	.card,
	.trade-card,
	.timeline-item,
	.stat-grid article,
	form {
		min-width: 0;
	}

	.hero {
		position: relative;
		overflow: hidden;
		padding: 112px 0 122px;
		background:
			radial-gradient(circle at 78% 18%, rgba(54, 178, 255, 0.28), transparent 30%),
			radial-gradient(circle at 16% 78%, rgba(214, 169, 53, 0.16), transparent 28%),
			linear-gradient(135deg, #0b1930 0%, #07111f 54%, #0c1725 100%);
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(109, 199, 255, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(109, 199, 255, 0.08) 1px, transparent 1px);
		background-size: 70px 70px;
		opacity: 0.24;
	}

	.hero-grid,
	.split,
	.cta-panel {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(460px, 0.95fr);
		gap: 64px;
		align-items: center;
	}

	.hero-copy {
		max-width: 760px;
	}

	.narrow-copy,
	.section-heading {
		max-width: 720px;
	}

	.eyebrow {
		margin: 0 0 16px;
		color: #d6a935;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		max-width: 720px;
		margin-bottom: 36px;
		font-size: clamp(3.2rem, 5.5vw, 5.7rem);
		line-height: 0.96;
		letter-spacing: 0;
	}

	h2 {
		margin-bottom: 24px;
		font-size: clamp(2.15rem, 4vw, 3.8rem);
		line-height: 1.02;
		letter-spacing: 0;
	}

	h3 {
		margin-bottom: 10px;
		font-size: 1.12rem;
		line-height: 1.25;
	}

	p {
		max-width: 68ch;
		color: #c7d8e8;
		font-size: 1.06rem;
		line-height: 1.85;
	}

	.hero-text {
		max-width: 660px;
		font-size: 1.18rem;
		line-height: 1.85;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		align-items: center;
		margin-top: 34px;
	}

	.button,
	button {
		display: inline-flex;
		max-width: 100%;
		align-items: center;
		justify-content: center;
		min-height: 52px;
		padding: 14px 22px;
		border: 0;
		border-radius: 8px;
		background: linear-gradient(135deg, #f0c85a, #d6a935);
		color: #07111f;
		font: inherit;
		font-weight: 900;
		overflow-wrap: anywhere;
		text-align: center;
		text-decoration: none;
		box-shadow: 0 16px 38px rgba(214, 169, 53, 0.24);
		cursor: pointer;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.button:hover,
	button:hover {
		transform: translateY(-2px);
		box-shadow: 0 0 34px rgba(214, 169, 53, 0.36);
	}

	.button.secondary {
		border: 1px solid rgba(109, 199, 255, 0.45);
		background: rgba(109, 199, 255, 0.08);
		color: #ffffff;
		box-shadow: none;
	}

	.button.secondary:hover {
		border-color: rgba(109, 199, 255, 0.9);
		box-shadow: 0 0 26px rgba(105, 213, 255, 0.22);
	}

	.product-visual {
		padding: 18px;
		border: 1px solid rgba(109, 199, 255, 0.2);
		border-radius: 24px;
		background: rgba(10, 25, 45, 0.54);
		box-shadow: 0 32px 100px rgba(0, 0, 0, 0.38);
	}

	.dashboard {
		padding: 24px;
		border: 1px solid rgba(109, 199, 255, 0.32);
		border-radius: 18px;
		background:
			radial-gradient(circle at 50% 0%, rgba(54, 178, 255, 0.24), transparent 38%),
			linear-gradient(135deg, rgba(9, 28, 54, 0.98), rgba(2, 9, 20, 0.98));
	}

	.dashboard-top,
	.panel-title {
		display: flex;
		justify-content: space-between;
		gap: 18px;
		align-items: center;
	}

	.dashboard-top {
		margin-bottom: 22px;
	}

	.dashboard-top span,
	.panel-title span {
		color: #69d5ff;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.dashboard-top strong,
	.panel-title strong {
		display: block;
		color: #ffffff;
	}

	.dashboard-top small {
		padding: 7px 10px;
		border: 1px solid rgba(109, 199, 255, 0.24);
		border-radius: 999px;
		color: #c7d8e8;
		font-weight: 800;
	}

	.metric-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
		margin-bottom: 16px;
	}

	.metric-grid div,
	.panel {
		border: 1px solid rgba(109, 199, 255, 0.18);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
	}

	.metric-grid div {
		padding: 16px;
	}

	.metric-grid span,
	.metric-grid strong {
		display: block;
	}

	.metric-grid span {
		min-height: 38px;
		color: #a9c0d7;
		font-size: 0.78rem;
		font-weight: 800;
	}

	.metric-grid strong {
		color: #ffffff;
		font-size: 1.5rem;
		line-height: 1.1;
	}

	.dashboard-body {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 12px;
	}

	.panel {
		padding: 16px;
	}

	.jobs-panel p {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 8px 12px;
		margin: 14px 0 0;
		color: #dce9f8;
		font-size: 0.92rem;
		line-height: 1.35;
	}

	.jobs-panel b {
		color: #69d5ff;
	}

	.jobs-panel p span {
		grid-column: 2;
		color: #9eb4ca;
	}

	.message-row {
		display: flex;
		gap: 10px;
		align-items: center;
		margin-top: 16px;
	}

	.avatar {
		display: grid;
		width: 34px;
		height: 34px;
		flex: 0 0 auto;
		place-items: center;
		border-radius: 999px;
		background: #d6a935;
		color: #07111f;
		font-size: 0.78rem;
		font-weight: 900;
	}

	.message-row p {
		margin: 0;
		color: #dce9f8;
		font-size: 0.9rem;
		line-height: 1.4;
	}

	.progress {
		height: 8px;
		margin-top: 18px;
		overflow: hidden;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.12);
	}

	.progress span {
		display: block;
		height: 100%;
		border-radius: inherit;
		background: linear-gradient(90deg, #69d5ff, #d6a935);
	}

	.section {
		padding: 112px 0;
	}

	.light,
	.muted {
		background: #f5f8fb;
		color: #0b1930;
	}

	.light h2,
	.light h3,
	.muted h2,
	.muted h3 {
		color: #0b1930;
	}

	.light p,
	.muted p {
		color: #536174;
	}

	.muted {
		background: #ffffff;
	}

	.dark {
		background: #07111f;
	}

	.section-heading {
		margin-bottom: 42px;
	}

	.problem-list,
	.card-grid,
	.trade-grid,
	.stat-grid,
	.week-timeline {
		display: grid;
		gap: 16px;
	}

	.problem-list,
	.stat-grid {
		grid-template-columns: 1fr;
	}

	.problem-list span,
	.card,
	.trade-card,
	.stat-grid article,
	.timeline-item {
		padding: 24px;
		border-radius: 14px;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.problem-list span,
	.card,
	.timeline-item {
		border: 1px solid rgba(12, 31, 55, 0.1);
		background: #ffffff;
		color: #0b1930;
		box-shadow: 0 20px 50px rgba(12, 31, 55, 0.07);
		font-weight: 850;
	}

	.week-timeline {
		position: relative;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.timeline-item {
		position: relative;
		min-height: 190px;
	}

	.timeline-item span {
		display: inline-flex;
		margin-bottom: 18px;
		padding: 8px 11px;
		border-radius: 999px;
		background: rgba(105, 213, 255, 0.12);
		color: #0b1930;
		font-size: 0.78rem;
		font-weight: 950;
		text-transform: uppercase;
	}

	.timeline-item p {
		margin: 0;
		color: #536174;
