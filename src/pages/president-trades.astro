			position: absolute;
			inset: 0;
			width: 100%;
			pointer-events: none;
		}

		.pt-hero-menu button {
			left: 48.4%;
			width: 7.6%;
			height: 3.9%;
			min-height: 0;
			background: transparent;
			color: transparent;
			pointer-events: auto;
		}

		.pt-hero-menu button:hover,
		.pt-hero-menu button:focus-visible {
			transform: none;
		}

		.pt-hero-visual img {
			width: 100%;
			height: auto;
			border-radius: 0;
			cursor: pointer;
		}

		.pt-hero-points {
			padding: 18px;
			border-radius: 12px;
