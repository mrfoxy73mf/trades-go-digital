---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";

export const prerender = false;

const heroButtons = [
	{
		label: "Dashboard",
		image: "/images/president-trades-dashboard.jpg",
		alt: "President Trades dashboard screen",
	},
	{
		label: "Quote Page",
		image: "/images/president-trades-quote-page.jpg",
		alt: "President Trades quote page screen",
	},
	{
		label: "Job Page",
		image: "/images/president-trades-job-folder.jpg",
		alt: "President Trades jobs screen",
	},
	{
		label: "Work Calendar",
		image: "/images/president-trades-work-calendar.jpg",
		alt: "President Trades work calendar screen",
	},
	{
		label: "Suppliers Page",
		image: "/images/president-trades-suppliers-page.jpg",
		alt: "President Trades suppliers page screen",
	},
	{
		label: "AI Assistant",
		image: "/images/president-trades-ai-assistant.jpg",
		alt: "President Trades AI Assistant screen",
	},
	{
		label: "Notebook",
		image: "/images/president-trades-notebook.jpg",
		alt: "President Trades notebook screen",
	},
	{
		label: "Business Office",
		image: "/images/president-trades-business-office.jpg",
		alt: "President Trades Business Office screen",
	},
	{
		label: "Vehicles and Logs",
		image: "/images/president-trades-vehicles-logs.jpg",
		alt: "President Trades vehicles and mileage logs screen",
	},
];

const paperworkItems = [
	{
		title: "Quote PDF",
		text: "Send a clear, professional quote to the customer.",
		image: "/images/president-trades-quote-pdf.png",
		alt: "President Trades quote PDF preview",
	},
	{
		title: "Job Sign-Off PDF",
		text: "Get the work signed off and keep the record with the job.",
		image: "/images/president-trades-job-signoff-pdf.png",
		alt: "President Trades job sign-off PDF preview",
	},
	{
		title: "Invoice PDF",
		text: "Create the invoice without typing everything again.",
		image: "/images/president-trades-invoice-pdf.png",
		alt: "President Trades invoice PDF preview",
	},
	{
		title: "Dividends",
		text: "Keep company paperwork ready for your accountant.",
		image: "/images/president-trades-dividends-pdf.png",
		alt: "President Trades dividends PDF preview",
	},
	{
		title: "Accountant",
		text: "Package the numbers your accountant needs.",
		image: "/images/president-trades-accountant-pdf.png",
		alt: "President Trades accountant report PDF preview",
	},
	{
		title: "Wage Slip",
		text: "Create clear wage records for the people you pay.",
		image: "/images/president-trades-wage-slip.jpg",
		alt: "President Trades wage slip preview",
	},
	{
		title: "Certificates & Sign-Offs",
		text: "Pick the right paperwork and keep certificates connected to the job.",
		label: "SCREEN",
		image: "/images/president-trades-certificates-screen.jpg",
		alt: "President Trades certificates and sign-off screen",
	},
];

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="President Trades - Business Software Built for UK Tradesmen | Trades Go Digital"
			description="President Trades is a business operating system for UK trades. One quote creates your job, calendar, PDFs, accounts and supplier orders automatically. Register your interest for early access."
		/>
		<meta property="og:site_name" content={SITE_TITLE} />
		<meta property="og:locale" content="en_GB" />
	</head>
	<body>
		<Header />
		<main class="pt-landing">
			<section class="pt-hero pt-section">
				<div class="pt-container pt-hero-inner">
					<div class="pt-hero-visual">
						<img
							id="pt-hero-preview"
							src="/images/president-trades-office-drawers-v3.png"
							alt="President Trades Magic Room office with branded van"
						/>
						<div class="pt-hero-cabinet-note">Open a drawer</div>
						<div class="pt-hero-return-note" hidden>Press picture to return to office</div>
						<div class="pt-hero-menu" aria-label="President Trades tools">
							{
								heroButtons.map((item) => (
									<button
										type="button"
										data-preview-src={item.image}
										data-preview-alt={item.alt}
									>
										<b>{item.label}</b>
									</button>
								))
							}
						</div>
					</div>
				</div>
				<section class="pt-image-caption" aria-label="President Trades introduction">
					<h2>President Trades - the business operating system built for UK trades</h2>
					<p>
						You already know how to run the job. President Trades runs the office. Quote once,
						and every job, PDF, calendar entry, supplier email and tax record falls into place
						automatically, right from your phone.
					</p>
					<ul>
						<li><strong>Dashboard</strong> - today's jobs, this week's takings and what needs your attention.</li>
						<li><strong>Quotes</strong> - create once, then let President Trades handle what happens next.</li>
						<li><strong>Jobs</strong> - every detail, note, photo and PDF lives with the job.</li>
						<li><strong>Work Calendar</strong> - accepted quotes can become booked work dates.</li>
						<li><strong>Suppliers</strong> - material lists and supplier invoices stay linked to the right job.</li>
						<li><strong>AI Assistant</strong> - ask about your business, your trade or the app.</li>
						<li><strong>Notebook</strong> - speak naturally and turn notes into proper messages.</li>
						<li><strong>Business Office</strong> - jobs, receipts, certificates and records organised together.</li>
						<li><strong>Vehicles and Mileage</strong> - log trips and keep mileage ready for your records.</li>
					</ul>
				</section>
			</section>

			<section id="paperwork" class="pt-section pt-paperwork">
				<div class="pt-container pt-paperwork-grid">
					<div class="pt-paperwork-visual">
						<div class="pt-paperwork-return-note" hidden>Press picture to return to files</div>
						<img
							id="pt-paperwork-preview"
							src="/images/president-trades-phone-files-v3.png"
							alt="President Trades phone showing business document files"
						/>
						<p class="pt-scroll-hint">Scroll left to see PDFs</p>
						<div class="pt-paperwork-menu" aria-label="President Trades paperwork previews">
							{
								paperworkItems.map((item) => (
									<button
										type="button"
										data-paperwork-src={item.image}
										data-paperwork-alt={item.alt}
									>
										<b>{item.title}</b>
										<span>{item.label || "PDF"}</span>
									</button>
								))
							}
						</div>
					</div>
				</div>
				<section class="pt-image-caption" aria-label="President Trades paperwork">
					<h2>All your paperwork - done, organised and ready to hand over</h2>
					<p>
						Every quote, invoice, sign-off, wage slip and certificate is created from the data
						you already put in. No copying, no re-typing and no chasing bits of paper.
					</p>
					<ul>
						<li><strong>Quote PDF</strong> - sent with one tap.</li>
						<li><strong>Job Sign-Off PDF</strong> - customer sign-off kept with the job.</li>
						<li><strong>Invoice PDF</strong> - created without typing everything again.</li>
						<li><strong>Dividends PDF</strong> - company paperwork ready for your records.</li>
						<li><strong>Accountant Report PDF</strong> - a tidy bundle for your accountant.</li>
						<li><strong>Wage Slips</strong> - clear wage records for people you pay.</li>
						<li><strong>Certificates and Sign-Offs</strong> - regulated paperwork connected to the job.</li>
					</ul>
				</section>
			</section>

			<section id="automatic" class="pt-section pt-auto">
				<div class="pt-container pt-image-section">
					<img
						src="/images/president-trades-time-saving-flows-v3.png"
						alt="President Trades time-saving flows showing less admin and more time back"
					/>
				</div>
				<section class="pt-image-caption" aria-label="How President Trades saves time">
					<h2>You do this once. President Trades does all this next.</h2>
					<p>
						Share a quote, the customer accepts, the job is created, paperwork is organised
						and customer records are updated. From that single moment, your business keeps
						moving with less effort from you.
					</p>
				</section>
			</section>

			<section id="features" class="pt-section pt-office">
				<div class="pt-container pt-image-section">
					<img
						src="/images/president-trades-business-office-v3.png"
						alt="President Trades Business Office organised around each job"
					/>
				</div>
				<section class="pt-image-caption" aria-label="President Trades Business Office">
					<h2>The Business Office - every job filed like a proper cabinet</h2>
					<p>
						President Trades files each quote, invoice, receipt, photo, certificate and note
						into the right job folder. Search by customer, date or job number, then send what
						your accountant needs when it is time.
					</p>
					<ul>
						<li>Jobs folder - one folder per job with every document inside.</li>
						<li>Certificates folder - regulated certificates kept signed and dated.</li>
						<li>Vehicle documents - MOT, insurance and service records.</li>
						<li>Financial folder - tax year archives, dividends and wages.</li>
						<li>PIN-protected - sensitive sections locked behind a second PIN.</li>
					</ul>
				</section>
			</section>

			<section class="pt-section pt-choose">
				<div class="pt-container pt-image-section">
					<img
						src="/images/president-trades-built-for-trades-v5.png"
						alt="President Trades built for the way trades work"
					/>
				</div>
				<section class="pt-image-caption" aria-label="President Trades built for UK trades">
					<h2>Built for the way trades actually work</h2>
					<p>
						Not for tech people. Not for office people. For the person in the van at 6am with
						muddy boots and a quote to send before the next call-out.
					</p>
					<ul>
						<li><strong>Works offline</strong> - no signal in the loft? Sync when you are back online.</li>
						<li><strong>UK trades tax built in</strong> - VAT, CIS, dividends and HMRC MTD-ready records.</li>
						<li><strong>Voice everything</strong> - say it in the van and write it up properly.</li>
						<li><strong>One-tap sharing</strong> - send quotes, invoices and job updates quickly.</li>
						<li><strong>PWA</strong> - installs like an app and works on any phone.</li>
					</ul>
				</section>
			</section>

			<section id="waiting-list" class="pt-section pt-site-footer-graphic">
				<div class="pt-container pt-image-section">
					<img
						src="/images/trades-go-digital-footer-v2.png"
						alt="Trades Go Digital app features, app pages and contact footer"
					/>
				</div>
				<section class="pt-image-caption" aria-label="President Trades early access">
					<h2>Be one of the first UK trades on President Trades</h2>
					<p>
						President Trades is being shaped around real UK trades businesses. Register your
						interest to get early access updates, launch pricing and a chance to shape the app
						around the way you actually work.
					</p>
				</section>
			</section>
		</main>
		<Footer />
		<script>
			const previewImage = document.querySelector<HTMLImageElement>("#pt-hero-preview");
			const previewVisual = document.querySelector<HTMLElement>(".pt-hero-visual");
			const previewReturnNote = document.querySelector<HTMLElement>(".pt-hero-return-note");
			const previewMenu = document.querySelector<HTMLElement>(".pt-hero-menu");
			const previewButtons = document.querySelectorAll<HTMLButtonElement>(".pt-hero-menu button");
			const paperworkImage = document.querySelector<HTMLImageElement>("#pt-paperwork-preview");
			const paperworkFrame = document.querySelector<HTMLElement>(".pt-paperwork-visual");
			const paperworkMenu = document.querySelector<HTMLElement>(".pt-paperwork-menu");
			const paperworkReturnNote = document.querySelector<HTMLElement>(".pt-paperwork-return-note");
			const paperworkButtons = document.querySelectorAll<HTMLButtonElement>(".pt-paperwork-menu button");
			const isPhone = () => window.matchMedia("(max-width: 720px)").matches;
			const scrollSectionStart = (element?: HTMLElement | null) => {
				const section = element?.closest<HTMLElement>(".pt-section");
				if (!section) return;
				const reset = () => {
					section.scrollLeft = 0;
				};
				reset();
				requestAnimationFrame(reset);
				window.setTimeout(reset, 200);
				window.setTimeout(reset, 700);
			};
			const scrollSectionEnd = (element?: HTMLElement | null) => {
				const section = element?.closest<HTMLElement>(".pt-section");
				if (!section) return;
				const reset = () => {
					section.scrollLeft = section.scrollWidth;
				};
				reset();
				requestAnimationFrame(reset);
				window.setTimeout(reset, 200);
				window.setTimeout(reset, 700);
			};

			previewButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const nextSrc = button.dataset.previewSrc;
					if (!previewImage || !nextSrc) return;

					previewImage.src = nextSrc;
					previewImage.alt = button.dataset.previewAlt || "President Trades app screen";
					previewButtons.forEach((item) => item.classList.remove("is-active"));
					button.classList.add("is-active");
					previewVisual?.classList.add("is-preview-open");
					if (previewReturnNote) {
						previewReturnNote.hidden = false;
					}

					if (isPhone()) {
						previewImage.scrollIntoView({ behavior: "smooth", block: "center" });
					}
					scrollSectionStart(previewVisual);
				});
			});

			paperworkButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const nextSrc = button.dataset.paperworkSrc;
					if (!paperworkImage || !nextSrc) return;

					paperworkImage.src = nextSrc;
					paperworkImage.alt = button.dataset.paperworkAlt || "President Trades paperwork preview";
					if (paperworkFrame) {
						paperworkFrame.scrollTop = 0;
						paperworkFrame.classList.add("is-paperwork-open");
					}
					if (paperworkReturnNote) {
						paperworkReturnNote.hidden = false;
					}
					paperworkButtons.forEach((item) => item.classList.remove("is-active"));
					button.classList.add("is-active");

					if (isPhone()) {
						paperworkImage.scrollIntoView({ behavior: "smooth", block: "center" });
					}
					scrollSectionStart(paperworkFrame);
				});
			});

			paperworkImage?.addEventListener("click", () => {
				if (!paperworkMenu) return;

				paperworkImage.src = "/images/president-trades-phone-files-v3.png";
				paperworkImage.alt = "President Trades phone showing business document files";
				if (paperworkFrame) {
					paperworkFrame.scrollTop = 0;
					paperworkFrame.classList.remove("is-paperwork-open");
				}
				if (paperworkReturnNote) {
					paperworkReturnNote.hidden = true;
				}
				paperworkButtons.forEach((item) => item.classList.remove("is-active"));

				if (isPhone()) {
					paperworkMenu.scrollIntoView({ behavior: "smooth", block: "start" });
				}
				scrollSectionEnd(paperworkFrame);
			});

			previewImage?.addEventListener("click", () => {
				if (!previewMenu) return;

				previewImage.src = "/images/president-trades-office-drawers-v3.png";
				previewImage.alt = "President Trades Magic Room office with branded van";
				previewVisual?.classList.remove("is-preview-open");
				if (previewReturnNote) {
					previewReturnNote.hidden = true;
				}
				previewButtons.forEach((item) => item.classList.remove("is-active"));

				if (isPhone()) {
					previewMenu.scrollIntoView({ behavior: "smooth", block: "start" });
				}
			});
		</script>
	</body>
</html>

<style>
	body {
		margin: 0;
		background: #02050a;
		color: #102033;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	html,
	body {
		overflow-x: hidden;
	}

	.pt-landing {
		--bg: #02050a;
		--bg-1: #070b12;
		--bg-2: #0d1420;
		--fg: #f8fafc;
		--muted: #cbd5e1;
		--dim: #94a3b8;
		--border: rgba(148, 163, 184, 0.22);
		--soft: rgba(148, 163, 184, 0.14);
		--accent: #ff6b00;
		--ok: #22c55e;
		background:
			radial-gradient(circle at 18% 0%, rgba(255, 107, 0, 0.16), transparent 30%),
			radial-gradient(circle at 88% 12%, rgba(59, 130, 246, 0.08), transparent 34%),
			linear-gradient(180deg, #02050a 0%, #050914 48%, #02050a 100%);
		color: var(--fg);
		overflow-x: hidden;
	}

	.pt-landing *,
	.pt-landing *::before,
	.pt-landing *::after {
		box-sizing: border-box;
	}

	.pt-container {
		width: min(1240px, calc(100% - 36px));
		margin: 0 auto;
	}

	.pt-section {
		position: relative;
		padding: 96px 0;
		border-bottom: 1px solid var(--soft);
	}

	.pt-hero {
		overflow: hidden;
		padding: 36px 0 76px;
	}

	.pt-hero-inner {
		position: relative;
		z-index: 2;
		display: block;
		width: min(1480px, calc(100% - 28px));
		margin: 0 auto;
	}

	.pt-logo {
		display: block;
		width: 82px;
		height: 82px;
		margin-bottom: 28px;
		border-radius: 50%;
		object-fit: cover;
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
	}

	.pt-hero-visual {
		position: relative;
		display: grid;
		place-items: center;
	}

	.pt-hero-visual img {
		width: 100%;
		height: auto;
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
		object-fit: contain;
	}

	.pt-hero-cabinet-note {
		display: none;
	}

	.pt-hero-return-note {
		position: absolute;
		left: 50%;
		bottom: 18px;
		z-index: 4;
		transform: translateX(-50%);
		padding: 8px 13px;
		border: 1px solid rgba(255, 159, 28, 0.45);
		border-radius: 999px;
		background: rgba(8, 13, 20, 0.82);
		color: #ffb14d;
		font-size: clamp(0.74rem, 0.85vw, 0.95rem);
		font-weight: 900;
		line-height: 1;
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.22);
		pointer-events: none;
	}

	.pt-hero-return-note[hidden],
	.pt-paperwork-return-note[hidden] {
		display: none;
	}

	.pt-hero-menu {
		position: absolute;
		inset: 0;
		z-index: 3;
		padding: 0;
		border: 0;
		background: transparent;
		box-shadow: none;
		pointer-events: none;
	}

	.pt-hero-menu button {
		position: absolute;
		left: 48.4%;
		width: 7.6%;
		height: 3.9%;
		appearance: none;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		min-height: 0;
		padding: 0;
		border: 0;
		border-radius: 6px;
		background: transparent;
		color: transparent;
		cursor: pointer;
		font-size: 0;
		font-weight: 900;
		letter-spacing: 0;
		line-height: 1.1;
		text-align: left;
		text-transform: none;
		pointer-events: auto;
		box-shadow: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.pt-hero-menu button::before {
		display: none;
	}

	.pt-hero-menu button::after {
		display: none;
	}

	.pt-hero-menu button:hover,
	.pt-hero-menu button:focus-visible {
		transform: none;
		border-color: transparent;
		background: transparent;
		color: transparent;
		outline: none;
	}

	.pt-hero-menu button.is-active {
		border-color: transparent;
		background: transparent;
		color: transparent;
		box-shadow: none;
	}

	.pt-hero-menu button.is-active:hover,
	.pt-hero-menu button.is-active:focus-visible {
		border-color: transparent;
		background: transparent;
		box-shadow: none;
	}

	.pt-hero-visual.is-preview-open .pt-hero-menu {
		display: none;
	}

	.pt-hero-menu button:nth-child(1) {
		top: 21.1%;
	}

	.pt-hero-menu button:nth-child(2) {
		top: 28.3%;
	}

	.pt-hero-menu button:nth-child(3) {
		top: 35.5%;
	}

	.pt-hero-menu button:nth-child(4) {
		top: 42.7%;
	}

	.pt-hero-menu button:nth-child(5) {
		top: 49.9%;
	}

	.pt-hero-menu button:nth-child(6) {
		top: 57%;
	}

	.pt-hero-menu button:nth-child(7) {
		top: 64.2%;
	}

	.pt-hero-menu button:nth-child(8) {
		top: 71.3%;
	}

	.pt-hero-menu button:nth-child(9) {
		top: 78.5%;
	}

	.pt-hero-menu b {
		font: inherit;
	}

	.pt-hero-points {
		display: none;
		gap: 18px;
		padding: 0;
		border: 0;
		background: transparent;
		box-shadow: none;
	}

	.pt-hero-points span {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 12px;
		align-items: start;
		color: var(--fg);
		font-size: 1rem;
		font-weight: 850;
		line-height: 1.35;
	}

	.pt-hero-points b {
		color: var(--accent);
		font-size: 1.05rem;
		line-height: 1.35;
	}

	.pt-topline,
	.pt-eyebrow {
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
		margin-bottom: 22px;
		color: var(--accent);
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
		overflow-wrap: anywhere;
	}

	h1 {
		max-width: 780px;
		margin-bottom: 32px;
		color: var(--fg);
		font-size: clamp(2.9rem, 7vw, 5.4rem);
		line-height: 1.06;
		letter-spacing: 0;
		text-wrap: balance;
	}

	h2 {
		max-width: 760px;
		margin-bottom: 22px;
		color: var(--fg);
		font-size: clamp(2.2rem, 5.4vw, 4rem);
		line-height: 1;
		letter-spacing: 0;
	}

	h2 span {
		color: var(--accent);
	}

	h3 {
		color: var(--fg);
		line-height: 1.25;
	}

	p {
		max-width: 680px;
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.pt-hero-lead {
		max-width: 720px;
		font-size: clamp(1.08rem, 1.6vw, 1.28rem);
	}

	.pt-trustline {
		margin-top: 24px;
		color: var(--dim);
		font-size: 0.9rem;
		font-weight: 800;
		letter-spacing: 0.04em;
	}

	.pt-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 36px;
	}

	.pt-btn,
	button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 52px;
		padding: 15px 22px;
		border: 1px solid transparent;
		border-radius: 4px;
		font: inherit;
		font-size: 0.78rem;
		font-weight: 950;
		letter-spacing: 0.13em;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
		transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
		cursor: pointer;
	}

	.pt-btn:hover,
	button:hover {
		transform: translateY(-2px);
	}

	.primary,
	button {
		background: var(--accent);
		color: #000;
		box-shadow: 0 18px 42px rgba(255, 107, 0, 0.22);
	}

	.primary:hover,
	button:hover {
		box-shadow: 0 0 34px rgba(255, 107, 0, 0.34);
	}

	.ghost {
		border-color: var(--border);
		background: transparent;
		color: var(--fg);
	}

	.ghost:hover {
		border-color: var(--muted);
		box-shadow: 0 0 26px rgba(148, 163, 184, 0.16);
	}

	.pt-trust {
		padding: 30px 0;
		background: #040812;
		border-bottom: 1px solid var(--soft);
	}

	.pt-trust-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 18px 32px;
	}

	.pt-trust-grid span,
	.pt-chip-grid span {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--muted);
		font-size: 0.76rem;
		font-weight: 850;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.pt-trust-grid b {
		color: var(--accent);
	}

	.pt-paperwork {
		background:
			linear-gradient(135deg, rgba(255, 107, 0, 0.08), transparent 42%),
			#02050a;
	}

	.pt-paperwork-grid {
		display: block;
		width: min(1480px, calc(100% - 28px));
		margin: 0 auto;
	}

	.pt-scroll-hint {
		display: none;
	}

	.pt-paperwork-punch {
		margin-top: 24px;
		color: var(--fg);
		font-weight: 900;
	}

	.pt-paperwork-menu {
		position: absolute;
		inset: 0;
		z-index: 3;
		pointer-events: none;
	}

	.pt-paperwork-menu button {
		position: absolute;
		width: 6%;
		height: 6%;
		appearance: none;
		display: block;
		min-height: 0;
		padding: 0;
		overflow: hidden;
		border: 0;
		border-radius: 999px;
		background: transparent;
		color: transparent;
		cursor: pointer;
		pointer-events: auto;
		text-align: left;
		box-shadow: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.pt-paperwork-menu button::before {
		display: none;
	}

	.pt-paperwork-menu button:hover,
	.pt-paperwork-menu button:focus-visible {
		transform: none;
		border-color: transparent;
		background: transparent;
		box-shadow: none;
		outline: none;
	}

	.pt-paperwork-menu button.is-active {
		border-color: transparent;
		background: transparent;
		color: transparent;
		box-shadow: none;
	}

	.pt-paperwork-menu button.is-active::before {
		display: none;
	}

	.pt-paperwork-menu b {
		color: inherit;
		font-size: 0;
		font-weight: 900;
		line-height: 1.25;
		letter-spacing: 0;
	}

	.pt-paperwork-menu span {
		display: none;
		align-items: center;
		min-height: 24px;
		padding: 4px 8px;
		border-radius: 999px;
		background: #111827;
		color: var(--dim);
		font-size: 0.62rem;
		font-weight: 950;
		letter-spacing: 0.08em;
	}

	.pt-paperwork-menu button.is-active span {
		display: none;
	}

	.pt-paperwork-menu button:nth-child(1) {
		left: 87.8%;
		top: 25.6%;
	}

	.pt-paperwork-menu button:nth-child(2) {
		left: 87.2%;
		top: 33.8%;
	}

	.pt-paperwork-menu button:nth-child(3) {
		left: 86.6%;
		top: 42%;
	}

	.pt-paperwork-menu button:nth-child(4) {
		left: 86%;
		top: 50.2%;
	}

	.pt-paperwork-menu button:nth-child(5) {
		left: 85.3%;
		top: 58.4%;
	}

	.pt-paperwork-menu button:nth-child(6) {
		left: 84.6%;
		top: 66.5%;
	}

	.pt-paperwork-menu button:nth-child(7) {
		left: 83.8%;
		top: 74.7%;
	}

	.pt-paperwork-visual {
		position: relative;
		display: block;
		max-height: none;
		overflow-y: auto;
		overflow-x: hidden;
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
		scrollbar-gutter: stable;
	}

	.pt-paperwork-visual.is-paperwork-open .pt-paperwork-menu {
		display: none;
	}

	.pt-paperwork-visual.is-paperwork-open {
		max-width: min(860px, calc(100vw - 32px));
		max-height: 78vh;
		margin: 0 auto;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 14px;
		background: #fff;
		box-shadow: 0 26px 70px rgba(0, 0, 0, 0.46);
	}

	.pt-paperwork-return-note {
		position: sticky;
		top: 14px;
		z-index: 4;
		display: table;
		margin: 14px auto -48px;
		padding: 8px 13px;
		border: 1px solid rgba(255, 159, 28, 0.45);
		border-radius: 999px;
		background: rgba(8, 13, 20, 0.82);
		color: #ffb14d;
		font-size: clamp(0.74rem, 0.85vw, 0.95rem);
		font-weight: 900;
		line-height: 1;
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.22);
		pointer-events: none;
	}

	.pt-paperwork-visual > img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0;
	}

	.pt-paperwork-visual.is-paperwork-open > img {
		border-radius: 14px;
	}

	.pt-paperwork-copy p:last-child {
		margin-bottom: 0;
	}

	.pt-paperwork-copy h2 {
		font-size: clamp(2rem, 4.3vw, 3.35rem);
	}

	.pt-image-section {
		width: min(1480px, calc(100% - 28px));
		margin: 0 auto;
	}

	.pt-image-section img {
		display: block;
		width: 100%;
		height: auto;
	}

	.pt-image-caption {
		width: min(920px, calc(100% - 32px));
		margin: 30px auto 0;
		text-align: center;
	}

	.pt-image-caption h2 {
		max-width: 820px;
		margin: 0 auto 14px;
		color: var(--fg);
		font-size: clamp(1.65rem, 3vw, 2.55rem);
		line-height: 1.1;
	}

	.pt-image-caption p {
		max-width: 780px;
		margin: 0 auto;
		color: var(--muted);
		font-size: clamp(1.04rem, 1.3vw, 1.18rem);
		line-height: 1.7;
	}

	.pt-image-caption ul {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
		max-width: 880px;
		margin: 22px auto 0;
		padding: 0;
		list-style: none;
		text-align: left;
	}

	.pt-image-caption li {
		padding: 14px 16px;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.045);
		color: var(--muted);
		font-size: 0.98rem;
		line-height: 1.55;
	}

	.pt-image-caption strong {
		color: var(--fg);
	}

	.pt-preview,
	.pt-office,
	.pt-pricing {
		background: var(--bg-1);
	}

	.pt-section-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr);
		gap: 40px;
		align-items: end;
		margin-bottom: 48px;
	}

	.pt-dashboard {
		overflow: hidden;
		padding: 32px;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: rgba(8, 13, 20, 0.78);
		box-shadow: 0 18px 54px rgba(0, 0, 0, 0.28);
	}

	.pt-dashboard-bar,
	.pt-dashboard-lower,
	.pt-kpi-grid,
	.pt-panel p,
	.pt-price,
	.pt-flow-card div {
		display: grid;
		gap: 16px;
	}

	.pt-dashboard-bar {
		grid-template-columns: 1fr auto;
		margin-bottom: 24px;
		color: var(--dim);
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.pt-dashboard-bar strong {
		color: var(--ok);
	}

	.pt-kpi-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 4px 4px 0 0;
		background: var(--border);
	}

	.pt-kpi-grid article,
	.pt-panel {
		background: #0b111c;
	}

	.pt-kpi-grid article {
		padding: 20px;
	}

	.pt-kpi-grid span,
	.pt-kpi-grid em,
	.pt-panel h3 {
		color: var(--muted);
		font-size: 0.68rem;
		font-style: normal;
		font-weight: 850;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.pt-kpi-grid b {
		display: block;
		margin: 8px 0;
		color: var(--fg);
		font-size: 1.8rem;
	}

	.pt-kpi-grid em {
		color: var(--accent);
	}

	.pt-dashboard-lower {
		grid-template-columns: 1.35fr 1fr;
		gap: 1px;
		border: 1px solid var(--border);
		border-top: 0;
		background: var(--border);
	}

	.pt-panel {
		padding: 22px;
	}

	.pt-panel p {
		grid-template-columns: 1fr auto auto;
		margin: 0;
		padding: 12px 0;
		border-bottom: 1px solid var(--soft);
		color: var(--muted);
		font-size: 0.8rem;
	}

	.pt-panel p:last-child {
		border-bottom: 0;
	}

	.pt-panel b {
		color: var(--fg);
	}

	.pt-panel em {
		color: var(--ok);
		font-style: normal;
		font-weight: 900;
	}

	.pt-bars {
		display: flex;
		align-items: flex-end;
		gap: 6px;
		height: 96px;
	}

	.pt-bars span {
		flex: 1;
		background: var(--border);
	}

	.pt-bars span:nth-child(8) {
		background: var(--accent);
	}

	.pt-axis {
		display: flex;
		justify-content: space-between;
		margin-top: 10px;
		color: var(--dim);
		font-size: 0.68rem;
		text-transform: uppercase;
	}

	.pt-flow-grid,
	.pt-ai-list {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 18px;
		margin-top: 36px;
	}

	.pt-flow-card,
	.pt-ai-list article,
	.pt-price-card {
		border: 1px solid var(--border);
		border-radius: 8px;
		background: linear-gradient(180deg, #111827, rgba(8, 13, 20, 0.94));
		transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
	}

	.pt-flow-card {
		padding: 24px;
	}

	.pt-flow-card:hover,
	.pt-ai-list article:hover,
	.pt-price-card:hover {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 0, 0.4);
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.36);
	}

	.pt-flow-card div {
		grid-template-columns: 1fr auto;
		align-items: center;
	}

	.pt-flow-card div span {
		color: var(--accent);
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.pt-flow-card div b {
		display: grid;
		width: 38px;
		height: 38px;
		place-items: center;
		border-radius: 8px;
		background: var(--accent);
		color: #000;
	}

	.pt-flow-card p,
	.pt-ai-list p {
		margin-bottom: 0;
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.pt-choose-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
		margin-top: 34px;
	}

	.pt-choose-grid article {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 12px;
		align-items: start;
		padding: 22px;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: #0b111c;
		box-shadow: 0 18px 45px rgba(0, 0, 0, 0.26);
		transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
	}

	.pt-choose-grid article:hover {
		transform: translateY(-3px);
		border-color: rgba(255, 107, 0, 0.36);
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
	}

	.pt-choose-grid span {
		color: var(--accent);
		font-weight: 950;
		line-height: 1.7;
	}

	.pt-choose-grid p {
		margin: 0;
		color: var(--fg);
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.55;
	}

	.pt-chip-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.pt-chip-grid span {
		padding: 12px 18px;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: #0b111c;
	}

	.pt-trade-proof {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 26px;
		align-items: center;
		margin-top: 42px;
		padding: 28px;
		border: 1px solid var(--border);
		border-radius: 18px;
		background: linear-gradient(135deg, rgba(17, 24, 39, 0.92), rgba(8, 13, 20, 0.72));
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.32);
	}

	.pt-trade-proof img {
		width: 150px;
		height: 150px;
		border: 1px solid rgba(255, 255, 255, 0.28);
		border-radius: 999px;
		object-fit: cover;
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.24);
	}

	.pt-trade-proof .pt-eyebrow {
		margin-bottom: 12px;
	}

	.pt-trade-proof h3 {
		max-width: 680px;
		margin-bottom: 10px;
		font-size: clamp(1.45rem, 2.4vw, 2.15rem);
	}

	.pt-trade-proof p:last-child {
		margin-bottom: 0;
	}

	.pt-ai-grid,
	.pt-pricing-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(420px, 1fr);
		gap: 64px;
		align-items: start;
	}

	.pt-ai-list {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-top: 0;
	}

	.pt-ai-list article {
		padding: 24px;
	}

	.pt-price-card {
		padding: 42px;
		background: #0b111c;
	}

	.pt-price {
		grid-template-columns: auto 1fr;
		align-items: end;
		gap: 10px;
	}

	.pt-price b {
		color: var(--accent);
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.95;
	}

	.pt-price span {
		color: var(--muted);
		font-weight: 900;
		text-transform: uppercase;
	}

	.pt-price-intro {
		margin: 12px 0 4px;
		color: #fb923c;
		font-size: 0.85rem;
		font-weight: 850;
	}

	.pt-price-after {
		margin: 0 0 24px;
		color: var(--dim);
		font-size: 0.82rem;
		font-weight: 850;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.pt-price-card ul {
		margin: 0 0 28px;
		padding: 0;
		list-style: none;
		border-top: 1px solid var(--soft);
	}

	.pt-price-card li {
		display: flex;
		gap: 12px;
		padding: 13px 0;
		border-bottom: 1px solid var(--soft);
		color: var(--muted);
	}

	.pt-price-card li span {
		color: var(--accent);
	}

	.pt-final {
		text-align: center;
	}

	.pt-final img {
		width: clamp(160px, 24vw, 280px);
		height: clamp(160px, 24vw, 280px);
		border-radius: 50%;
		object-fit: cover;
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
	}

	.pt-final h2,
	.pt-final p {
		margin-left: auto;
		margin-right: auto;
	}

	form {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
		width: min(760px, 100%);
		margin: 42px auto 0;
		text-align: left;
	}

	label {
		display: grid;
		gap: 8px;
		color: var(--fg);
		font-size: 0.94rem;
		font-weight: 850;
	}

	label.full,
	form button,
	.form-note {
		grid-column: 1 / -1;
	}

	input,
	textarea {
		width: 100%;
		min-width: 0;
		min-height: 52px;
		border: 1px solid rgba(148, 163, 184, 0.28);
		border-radius: 8px;
		background: #0b111c;
		color: var(--fg);
		font: inherit;
		font-size: 1rem;
		padding: 14px;
	}

	textarea {
		min-height: 132px;
		resize: vertical;
	}

	input::placeholder,
	textarea::placeholder {
		color: #718096;
	}

	.form-note,
	.email-note {
		margin-bottom: 0;
		color: var(--muted);
		font-size: 0.95rem;
	}

	.email-note a {
		color: var(--accent);
		font-weight: 900;
	}

	@media (max-width: 1000px) {
		.pt-hero-inner,
		.pt-section-head,
		.pt-paperwork-grid,
		.pt-ai-grid,
		.pt-pricing-grid {
			grid-template-columns: 1fr;
		}

		.pt-kpi-grid,
		.pt-flow-grid,
		.pt-choose-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.pt-dashboard-lower {
			grid-template-columns: 1fr;
		}

		.pt-hero,
		.pt-paperwork,
		.pt-auto,
		.pt-office,
		.pt-choose,
		.pt-site-footer-graphic {
			overflow-x: hidden;
		}

		.pt-hero-inner,
		.pt-paperwork-grid,
		.pt-image-section {
			width: min(100% - 28px, 1180px);
			min-width: 100%;
			padding-inline: 0;
		}

		.pt-image-caption {
			width: min(860px, calc(100% - 32px));
			margin-top: 26px;
		}

		.pt-hero-visual,
		.pt-paperwork-visual,
		.pt-image-section img {
			width: 100%;
			max-width: 100%;
		}

		.pt-paperwork-visual.is-paperwork-open {
			width: min(860px, calc(100vw - 28px));
			max-width: none;
		}

		.pt-paperwork-visual.is-paperwork-open > img {
			width: 100%;
		}

		.pt-scroll-hint {
			position: absolute;
			left: 2.2%;
			top: 79.5%;
			z-index: 5;
			display: table;
			width: max-content;
			max-width: 240px;
			margin: 0;
			padding: 9px 13px;
			border: 1px solid rgba(255, 159, 28, 0.45);
			border-radius: 999px;
			background: rgba(8, 13, 20, 0.88);
			color: #ffb14d;
			font-size: 0.78rem;
			font-weight: 900;
			line-height: 1.15;
			box-shadow: 0 12px 30px rgba(0, 0, 0, 0.24);
			pointer-events: none;
		}

		.pt-paperwork-visual.is-paperwork-open .pt-scroll-hint {
			display: none;
		}
	}

	@media (max-width: 720px) {
		.pt-section,
		.pt-hero {
			padding: 56px 0;
		}

		.pt-hero-inner {
			gap: 22px;
			width: min(100% - 16px, 620px);
			margin: 0 auto;
			padding-inline: 0;
		}

		.pt-hero-visual {
			justify-content: center;
			width: 100%;
		}

		.pt-hero-visual.is-preview-open {
			width: calc(100vw - 16px);
		}

		.pt-hero-menu {
			position: absolute;
			inset: 0;
			width: 100%;
			pointer-events: none;
		}

		.pt-hero-menu button {
			left: 48.4%;
			width: 7.6%;
			height: 3.9%;
			min-height: 0;
			background: transparent;
