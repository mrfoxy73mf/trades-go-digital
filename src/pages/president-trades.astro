---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { CONTACT_EMAIL, SITE_TITLE } from "../consts";

const trustItems = [
	"Works from your phone",
	"Built for UK trade businesses",
	"Quotes, jobs and paperwork in one place",
	"Your business office in your pocket",
	"Simple admin. No clutter.",
];

const heroButtons = [
	{
		label: "Dashboard",
		image: "/images/president-trades-dashboard.jpg",
		alt: "President Trades dashboard screen",
	},
	{
		label: "Quote Page",
		image: "/images/president-trades-quote-page.jpg",
		alt: "President Trades quote page screen",
	},
	{
		label: "Job Page",
		image: "/images/president-trades-job-folder.jpg",
		alt: "President Trades jobs screen",
	},
	{
		label: "Work Calendar",
		image: "/images/president-trades-work-calendar.jpg",
		alt: "President Trades work calendar screen",
	},
	{ label: "Receipt Tracking" },
	{ label: "Archives" },
	{ label: "Certificates" },
	{ label: "Tax Centre" },
	{ label: "Vehicle & Mileage Logs" },
];

const kpis = [
	["INCOME - YTD", "GBP 28,420", "+12.4%"],
	["YOU KEEP", "GBP 24,180", "+9.8%"],
	["PROFIT", "GBP 18,940", "+15.1%"],
	["OUTSTANDING", "GBP 7,220", "-2.3%"],
];

const activeJobs = [
	["MRS PATEL - BOILER SERVICE", "GBP 280", "DONE"],
	["RIVERSIDE ESTATE - AGENCY", "GBP 1,440", "OUTSTAND"],
	["MR KHAN - TAP REPLACE", "GBP 120", "DONE"],
];

const flows = [
	{
		tag: "Instant",
		title: "Quote to Job Pack in seconds",
		text: "Customer accepts the quote and the invoice is created automatically and organised in the Business Office.",
	},
	{
		tag: "Live",
		title: "Job records stay organised",
		text: "Quotes, invoices, certificates and customer details stay together so you can find what you need later.",
	},
	{
		tag: "One-time",
		title: "Materials ready when you need them",
		text: "Build quotes faster with saved labour, materials and common part lists. Add your regular items once, reuse them on future jobs, and keep pricing more consistent across quotes and invoices.",
	},
	{
		tag: "One tap",
		title: "Month-end ready for your accountant",
		text: "Choose the month, then download, share or email one tidy bundle with receipts, invoices, mileage and import-ready records.",
	},
];

const officeItems = [
	"Job folders",
	"Work calendar",
	"Notebook and voice notes",
	"Accountant exports",
	"Receipt tracking",
	"Archives",
	"Certificates",
	"Tax centre",
	"Vehicle and mileage logs",
];

const aiItems = [
	["Voice notes that tidy themselves", "Dictate job notes, customer updates and reminders, then turn them into clear wording when you need it."],
	["Customer messages made easier", "Draft polite follow-ups, payment reminders and job updates without starting from a blank page."],
	["Hands-free on site", "Capture details while you are working, then organise them properly when you have time."],
	["Built around UK trades admin", "Designed for the notes, paperwork and follow-ups UK trades businesses deal with every week."],
];

const priceItems = [
	"Quotes, jobs, invoices and certificates",
	"Business Office with organised job records",
	"Tax Centre and accountant bundle",
	"Notebook, voice notes and useful AI tools",
	"Vehicle, mileage and calendar",
	"Business branding on paperwork",
];

const waitingListFields = ["Name", "Business Name", "Trade", "Email", "Phone (optional)"];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="President Trades | Business Operating System for UK Trades"
			description="President Trades is a business operating system for UK trades businesses. Register your interest for early access."
		/>
		<meta property="og:site_name" content={SITE_TITLE} />
		<meta property="og:title" content="President Trades | Business Operating System for UK Trades" />
		<meta
			property="og:description"
			content="Run quotes, jobs, invoices, receipts, certificates, VAT records and payment chasing from one organised place."
		/>
		<meta property="og:locale" content="en_GB" />
	</head>
	<body>
		<Header />
		<main class="pt-landing">
			<section class="pt-hero pt-section">
				<div class="pt-container pt-hero-inner">
					<div class="pt-hero-menu" aria-label="President Trades tools">
						{
							heroButtons.map((item) => (
								<button
									type="button"
									data-preview-src={item.image}
									data-preview-alt={item.alt}
								>
									<b>{item.label}</b>
								</button>
							))
						}
					</div>
					<div class="pt-hero-visual">
						<img
							id="pt-hero-preview"
							src="/images/president-trades-magic-room.png"
							alt="President Trades Magic Room office with branded van"
						/>
					</div>
					<div class="pt-hero-points" aria-label="President Trades key benefits">
						{trustItems.map((item) => <span><b>&check;</b>{item}</span>)}
					</div>
				</div>
			</section>

			<section id="preview" class="pt-section pt-preview">
				<div class="pt-container">
					<p class="pt-eyebrow">Why it's easy</p>
					<div class="pt-section-head">
						<h2>Tap less.<br /><span>Finish earlier.</span></h2>
						<p>
							President Trades is a business operating system for UK trades businesses. It helps
							keep quotes, jobs, invoices, certificates, receipts and customer records together
							in one place.
						</p>
					</div>
					<div class="pt-dashboard">
						<div class="pt-dashboard-bar">
							<span>// Live preview - dashboard module</span>
							<strong>System online</strong>
						</div>
						<div class="pt-kpi-grid">
							{kpis.map(([label, value, delta]) => <article><span>{label}</span><b>{value}</b><em>{delta}</em></article>)}
						</div>
						<div class="pt-dashboard-lower">
							<div class="pt-panel">
								<h3>// Active jobs</h3>
								{activeJobs.map(([name, amount, status]) => <p><span>{name}</span><b>{amount}</b><em>{status}</em></p>)}
							</div>
							<div class="pt-panel">
								<h3>// 12-month volume</h3>
								<div class="pt-bars" aria-hidden="true">
									{[38, 60, 50, 76, 92, 70, 84, 100, 58, 72, 88, 82].map((height) => <span style={`height: ${height}%`}></span>)}
								</div>
								<div class="pt-axis"><span>Mar</span><span>Feb</span></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="automatic" class="pt-section pt-auto">
				<div class="pt-container">
					<p class="pt-eyebrow">Time-saving flows</p>
					<h2>Less admin.<br /><span>More time back.</span></h2>
					<div class="pt-flow-grid">
						{
							flows.map((flow) => (
								<article class="pt-flow-card">
									<div><span>{flow.tag}</span><b>↗</b></div>
									<h3>{flow.title}</h3>
									<p>{flow.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="features" class="pt-section pt-office">
				<div class="pt-container">
					<p class="pt-eyebrow">Business office</p>
					<div class="pt-section-head">
						<h2>Everything organised <span>around each job.</span></h2>
						<p>
							Quotes, jobs, certificates, expenses, mileage and tax records are grouped around
							the way a trade business actually works.
						</p>
					</div>
					<div class="pt-chip-grid">
						{officeItems.map((item) => <span>{item}</span>)}
					</div>
					<div class="pt-trade-proof">
						<img
							src="/images/president-trades-worker-badge.png"
							alt="President Trades worker and van"
						/>
						<div>
							<p class="pt-eyebrow">Built around the work</p>
							<h3>Made for trades businesses that live between site, van and home.</h3>
							<p>
								President Trades keeps the business office close by, so job records, paperwork
								and follow-ups stay organised wherever the working day takes you.
							</p>
						</div>
					</div>
				</div>
			</section>

			<section class="pt-section pt-ai">
				<div class="pt-container pt-ai-grid">
					<div>
						<p class="pt-eyebrow">Notebook and voice tools</p>
						<h2>Talk it through.<br /><span>Tidy it up later.</span></h2>
						<p>
							Capture job notes, customer updates, reminders and follow-ups while you are
							working. President Trades helps turn rough notes into clearer records and
							messages, without taking control away from you.
						</p>
					</div>
					<div class="pt-ai-list">
						{aiItems.map(([title, text]) => <article><h3>{title}</h3><p>{text}</p></article>)}
					</div>
				</div>
			</section>

			<section id="pricing" class="pt-section pt-pricing">
				<div class="pt-container pt-pricing-grid">
					<div>
						<p class="pt-eyebrow">Pricing</p>
						<h2>One plan.<br />One price.<br /><span>Built for trades.</span></h2>
						<p>Simple pricing with the core business office included.</p>
					</div>
					<article class="pt-price-card">
						<div class="pt-price"><b>&pound;28</b><span>/month</span></div>
						<p class="pt-price-intro">Less than &pound;1 a day for your first 2 months.</p>
						<p class="pt-price-after">Then &pound;60 a month.</p>
						<ul>
							{priceItems.map((item) => <li><span>✓</span>{item}</li>)}
						</ul>
						<a class="pt-btn primary" href="#waiting-list">Register Your Interest</a>
					</article>
				</div>
			</section>

			<section id="waiting-list" class="pt-section pt-final">
				<div class="pt-container">
					<img src="/president-trades-logo.png" alt="President Trades" />
					<h2>Give yourself your evenings back.</h2>
					<p>No paperwork pile-up. No shoebox. Just the work, organised.</p>
					<form aria-label="President Trades waiting list form">
						{
							waitingListFields.map((field) => (
								<label>
									{field}
									<input type={field === "Email" ? "email" : field.includes("Phone") ? "tel" : "text"} placeholder={field} />
								</label>
							))
						}
						<label class="full">
							Message
							<textarea rows="4" placeholder="What admin problem would you most like solved?"></textarea>
						</label>
						<button type="button">Register Your Interest</button>
						<p class="form-note">Early access list opening soon. No spam. We'll only contact you about President Trades.</p>
					</form>
					<p class="email-note">
						Prefer email? <a href={`mailto:${CONTACT_EMAIL}?subject=President%20Trades%20Early%20Access`}>{CONTACT_EMAIL}</a>
					</p>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			const previewImage = document.querySelector<HTMLImageElement>("#pt-hero-preview");
			const previewMenu = document.querySelector<HTMLElement>(".pt-hero-menu");
			const previewButtons = document.querySelectorAll<HTMLButtonElement>(".pt-hero-menu button");
			const isPhone = () => window.matchMedia("(max-width: 720px)").matches;

			previewButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const nextSrc = button.dataset.previewSrc;
					if (!previewImage || !nextSrc) return;

					previewImage.src = nextSrc;
					previewImage.alt = button.dataset.previewAlt || "President Trades app screen";
					previewButtons.forEach((item) => item.classList.remove("is-active"));
					button.classList.add("is-active");

					if (isPhone()) {
						previewImage.scrollIntoView({ behavior: "smooth", block: "center" });
					}
				});
			});

			previewImage?.addEventListener("click", () => {
				if (!previewMenu) return;

				previewImage.src = "/images/president-trades-magic-room.png";
				previewImage.alt = "President Trades Magic Room office with branded van";
				previewButtons.forEach((item) => item.classList.remove("is-active"));

				if (isPhone()) {
					previewMenu.scrollIntoView({ behavior: "smooth", block: "start" });
				}
			});
		</script>
	</body>
</html>

<style>
	body {
		margin: 0;
		background: #244057;
		color: #f8fafc;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	html,
	body {
		overflow-x: hidden;
	}

	.pt-landing {
		--bg: #244057;
		--bg-1: #2d4f6a;
		--bg-2: #37617f;
		--fg: #f8fafc;
		--muted: #d5e0ea;
		--dim: #b5c6d5;
		--border: #63819b;
		--soft: #4f708c;
		--accent: #ff6b00;
		--ok: #22c55e;
		background:
			radial-gradient(circle at 18% 0%, rgba(255, 107, 0, 0.12), transparent 26%),
			radial-gradient(circle at 88% 12%, rgba(166, 205, 232, 0.28), transparent 30%),
			linear-gradient(180deg, #315774 0%, var(--bg) 44%, #20384f 100%);
		color: var(--fg);
		overflow-x: hidden;
	}

	.pt-landing *,
	.pt-landing *::before,
	.pt-landing *::after {
		box-sizing: border-box;
	}

	.pt-container {
		width: min(1240px, calc(100% - 36px));
		margin: 0 auto;
	}

	.pt-section {
		position: relative;
		padding: 96px 0;
		border-bottom: 1px solid var(--soft);
	}

	.pt-hero {
		overflow: hidden;
		padding: 48px 0 76px;
	}

	.pt-hero-inner {
		position: relative;
		z-index: 2;
		display: grid;
		grid-template-columns: minmax(180px, 230px) minmax(0, 1fr) minmax(240px, 320px);
		gap: 28px;
		align-items: center;
		width: min(1500px, calc(100% - 36px));
	}

	.pt-logo {
		display: block;
		width: 82px;
		height: 82px;
		margin-bottom: 28px;
		border-radius: 50%;
		object-fit: cover;
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
	}

	.pt-hero-visual {
		display: grid;
		place-items: center;
	}

	.pt-hero-visual img {
		width: 100%;
		height: auto;
		border: 1px solid rgba(255, 255, 255, 0.32);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.08);
		box-shadow:
			0 34px 90px rgba(0, 0, 0, 0.26),
			0 0 0 8px rgba(255, 255, 255, 0.05);
		object-fit: contain;
	}

	.pt-hero-menu {
		display: grid;
		gap: 10px;
	}

	.pt-hero-menu button {
		width: 100%;
		appearance: none;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		min-height: 46px;
		padding: 11px 14px;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.1);
		color: var(--fg);
		cursor: pointer;
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0;
		line-height: 1.25;
		text-align: left;
		text-transform: none;
		box-shadow: 0 12px 34px rgba(0, 0, 0, 0.12);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.pt-hero-menu button:hover,
	.pt-hero-menu button:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(244, 151, 36, 0.65);
		background: rgba(255, 255, 255, 0.16);
		outline: none;
	}

	.pt-hero-menu button.is-active {
		border-color: rgba(255, 177, 77, 0.88);
		background: linear-gradient(135deg, #f47b20 0%, #ff8a24 52%, #ffae45 100%);
		color: #111827;
		box-shadow:
			0 16px 38px rgba(244, 123, 32, 0.3),
			inset 0 1px 0 rgba(255, 255, 255, 0.35);
	}

	.pt-hero-menu button.is-active:hover,
	.pt-hero-menu button.is-active:focus-visible {
		border-color: rgba(255, 194, 102, 0.95);
		background: linear-gradient(135deg, #f47b20 0%, #ff8a24 52%, #ffae45 100%);
		box-shadow:
			0 18px 42px rgba(244, 123, 32, 0.36),
			inset 0 1px 0 rgba(255, 255, 255, 0.4);
	}

	.pt-hero-menu b {
		font: inherit;
	}

	.pt-hero-points {
		display: grid;
		gap: 18px;
		padding: 0;
		border: 0;
		background: transparent;
		box-shadow: none;
	}

	.pt-hero-points span {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 12px;
		align-items: start;
		color: var(--fg);
		font-size: 1rem;
		font-weight: 850;
		line-height: 1.35;
	}

	.pt-hero-points b {
		color: var(--accent);
		font-size: 1.05rem;
		line-height: 1.35;
	}

	.pt-topline,
	.pt-eyebrow {
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
		margin-bottom: 22px;
		color: var(--accent);
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
		overflow-wrap: anywhere;
	}

	h1 {
		max-width: 780px;
		margin-bottom: 32px;
		color: var(--fg);
		font-size: clamp(2.9rem, 7vw, 5.4rem);
		line-height: 1.06;
		letter-spacing: 0;
		text-wrap: balance;
	}

	h2 {
		max-width: 760px;
		margin-bottom: 22px;
		color: var(--fg);
		font-size: clamp(2.2rem, 5.4vw, 4rem);
		line-height: 1;
		letter-spacing: 0;
	}

	h2 span {
		color: var(--accent);
	}

	h3 {
		color: var(--fg);
		line-height: 1.25;
	}

	p {
		max-width: 680px;
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.pt-hero-lead {
		max-width: 720px;
		font-size: clamp(1.08rem, 1.6vw, 1.28rem);
	}

	.pt-trustline {
		margin-top: 24px;
		color: var(--dim);
		font-size: 0.9rem;
		font-weight: 800;
		letter-spacing: 0.04em;
	}

	.pt-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 36px;
	}

	.pt-btn,
	button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 52px;
		padding: 15px 22px;
		border: 1px solid transparent;
		border-radius: 4px;
		font: inherit;
		font-size: 0.78rem;
		font-weight: 950;
		letter-spacing: 0.13em;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
		transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
		cursor: pointer;
	}

	.pt-btn:hover,
	button:hover {
		transform: translateY(-2px);
	}

	.primary,
	button {
		background: var(--accent);
		color: #000;
		box-shadow: 0 18px 42px rgba(255, 107, 0, 0.22);
	}

	.primary:hover,
	button:hover {
		box-shadow: 0 0 34px rgba(255, 107, 0, 0.34);
	}

	.ghost {
		border-color: var(--border);
		background: transparent;
		color: var(--fg);
	}

	.ghost:hover {
		border-color: var(--muted);
		box-shadow: 0 0 26px rgba(148, 163, 184, 0.16);
	}

	.pt-trust {
		padding: 30px 0;
		background: #20384f;
		border-bottom: 1px solid var(--soft);
	}

	.pt-trust-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 18px 32px;
	}

	.pt-trust-grid span,
	.pt-chip-grid span {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--muted);
		font-size: 0.76rem;
		font-weight: 850;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.pt-trust-grid b {
		color: var(--accent);
	}

	.pt-preview,
	.pt-office,
	.pt-pricing {
		background: var(--bg-1);
	}

	.pt-section-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr);
		gap: 40px;
		align-items: end;
		margin-bottom: 48px;
	}

	.pt-dashboard {
		overflow: hidden;
		padding: 32px;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: #294b66;
	}

	.pt-dashboard-bar,
	.pt-dashboard-lower,
	.pt-kpi-grid,
	.pt-panel p,
	.pt-price,
	.pt-flow-card div {
		display: grid;
		gap: 16px;
	}

	.pt-dashboard-bar {
		grid-template-columns: 1fr auto;
		margin-bottom: 24px;
		color: var(--dim);
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.pt-dashboard-bar strong {
		color: var(--ok);
	}

	.pt-kpi-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 4px 4px 0 0;
		background: var(--border);
	}

	.pt-kpi-grid article,
	.pt-panel {
		background: #2d4f6a;
	}

	.pt-kpi-grid article {
		padding: 20px;
	}

	.pt-kpi-grid span,
	.pt-kpi-grid em,
	.pt-panel h3 {
		color: var(--muted);
		font-size: 0.68rem;
		font-style: normal;
		font-weight: 850;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.pt-kpi-grid b {
		display: block;
		margin: 8px 0;
		color: var(--fg);
		font-size: 1.8rem;
	}

	.pt-kpi-grid em {
		color: var(--accent);
	}

	.pt-dashboard-lower {
